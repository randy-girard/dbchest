<% content_for :title, "Credentials" %>

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Clusters", clusters_path %></li>
            <li class="breadcrumb-item"><%= link_to @cluster.name, @cluster %></li>
            <li class="breadcrumb-item"><%= link_to @node.name, [@cluster, @node] %></li>
            <li class="breadcrumb-item active" aria-current="page">Credentials</li>
          </ol>
        </nav>
        <div class="page-pretitle">Credential Management</div>
        <h2 class="page-title">Credentials for <%= @node.name %></h2>
        <div class="text-muted mt-1"><%= pluralize(@credentials.count, 'credential') %> configured</div>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <%= link_to new_cluster_node_credential_path(@cluster, @node), class: "btn btn-primary" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <line x1="12" y1="5" x2="12" y2="19"/>
            <line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          New Credential
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <% if @credentials.any? %>
      <div class="card">
        <div class="table-responsive">
          <table class="table table-vcenter">
            <thead>
              <tr>
                <th>Username</th>
                <th>Database</th>
                <th>Type</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @credentials.each do |credential| %>
                <tr>
                  <td>
                    <div class="fw-bold"><%= credential.username %></div>
                  </td>
                  <td>
                    <span class="text-muted"><%= credential.database_name || '—' %></span>
                  </td>
                  <td>
                    <span class="badge bg-info"><%= credential.credential_type || 'Standard' %></span>
                  </td>
                  <td>
                    <div class="text-muted"><%= time_ago_in_words(credential.created_at) %> ago</div>
                    <div class="text-muted small"><%= credential.created_at.strftime("%b %d, %Y") %></div>
                  </td>
                  <td>
                    <div class="btn-list justify-content-end">
                      <%= link_to cluster_node_credential_path(@cluster, @node, credential), class: "btn btn-sm btn-outline-primary", title: "View Details" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                          <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                        </svg>
                      <% end %>
                      <%= link_to edit_cluster_node_credential_path(@cluster, @node, credential), class: "btn btn-sm btn-outline-secondary", title: "Edit" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                          <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
                        </svg>
                      <% end %>
                      <%= button_to cluster_node_credential_path(@cluster, @node, credential), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger", title: "Delete" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <line x1="4" y1="7" x2="20" y2="7"/>
                          <line x1="10" y1="11" x2="10" y2="17"/>
                          <line x1="14" y1="11" x2="14" y2="17"/>
                          <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                          <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                        </svg>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="empty">
        <div class="empty-img">
          <img src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/img/illustrations/undraw_secure_login_pdn4.svg" height="128" alt="">
        </div>
        <p class="empty-title">No credentials found</p>
        <p class="empty-subtitle text-muted">
          Add your first credential to access this database node.
        </p>
        <div class="empty-action">
          <%= link_to "Add first credential", new_cluster_node_credential_path(@cluster, @node), class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
