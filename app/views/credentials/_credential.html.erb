<div id="<%= dom_id credential %>" class="credential-details">
  <div class="row">
    <div class="col-md-6">
      <dl class="row">
        <dt class="col-sm-4">Username:</dt>
        <dd class="col-sm-8">
          <div class="d-flex align-items-center">
            <span class="avatar avatar-sm me-2" style="background-image: url(https://ui-avatars.com/api/?name=<%= credential.username %>&background=dc3545&color=fff)"></span>
            <strong><%= credential.username %></strong>
          </div>
        </dd>
        
        <dt class="col-sm-4">Password:</dt>
        <dd class="col-sm-8">
          <div class="input-group">
            <input type="password" class="form-control" value="<%= credential.password %>" readonly id="password-<%= credential.id %>">
            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('<%= credential.id %>')">
              <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
              </svg>
            </button>
          </div>
        </dd>
        
        <dt class="col-sm-4">Role:</dt>
        <dd class="col-sm-8">
          <span class="badge bg-info">
            <%= credential.respond_to?(:role) && credential.role.present? ? credential.role.humanize : 'User' %>
          </span>
        </dd>

        <dt class="col-sm-4">Status:</dt>
        <dd class="col-sm-8">
          <span class="badge bg-success">Active</span>
        </dd>
      </dl>
    </div>
    
    <div class="col-md-6">
      <dl class="row">
        <dt class="col-sm-4">Created:</dt>
        <dd class="col-sm-8">
          <%= credential.created_at.strftime("%B %d, %Y at %I:%M %p") %>
          <small class="text-muted d-block">(<%= time_ago_in_words(credential.created_at) %> ago)</small>
        </dd>
        
        <dt class="col-sm-4">Updated:</dt>
        <dd class="col-sm-8">
          <%= credential.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
          <small class="text-muted d-block">(<%= time_ago_in_words(credential.updated_at) %> ago)</small>
        </dd>

        <dt class="col-sm-4">Node:</dt>
        <dd class="col-sm-8">
          <% if defined?(@node) && @node %>
            <%= link_to @node.name, cluster_node_path(@cluster, @node), class: "text-decoration-none" %>
          <% elsif credential.respond_to?(:node) && credential.node %>
            <%= credential.node.name %>
          <% else %>
            <span class="text-muted">Unknown</span>
          <% end %>
        </dd>

        <dt class="col-sm-4">Cluster:</dt>
        <dd class="col-sm-8">
          <% if defined?(@cluster) && @cluster %>
            <%= link_to @cluster.name, cluster_path(@cluster), class: "text-decoration-none" %>
          <% elsif credential.respond_to?(:cluster) && credential.cluster %>
            <%= credential.cluster.name %>
          <% else %>
            <span class="text-muted">Unknown</span>
          <% end %>
        </dd>
      </dl>
    </div>
  </div>
  
  <% if credential.respond_to?(:description) && credential.description.present? %>
    <div class="mt-3">
      <dt>Description:</dt>
      <dd class="mt-2">
        <div class="card bg-light">
          <div class="card-body">
            <%= simple_format(credential.description) %>
          </div>
        </div>
      </dd>
    </div>
  <% end %>

  <!-- Security Information -->
  <div class="mt-4">
    <div class="card bg-light">
      <div class="card-header">
        <h4 class="card-title">Security Information</h4>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-3">
            <div class="text-muted small">Password Length</div>
            <div class="fw-bold"><%= credential.password.length %> characters</div>
          </div>
          <div class="col-md-3">
            <div class="text-muted small">Last Password Change</div>
            <div class="fw-bold">
              <%= time_ago_in_words(credential.updated_at) %> ago
            </div>
          </div>
          <div class="col-md-3">
            <div class="text-muted small">Access Level</div>
            <div class="fw-bold">
              <%= credential.respond_to?(:role) && credential.role.present? ? credential.role.humanize : 'Standard' %>
            </div>
          </div>
          <div class="col-md-3">
            <div class="text-muted small">Security Status</div>
            <div class="fw-bold text-success">Secure</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function togglePassword(credentialId) {
    const passwordField = document.getElementById('password-' + credentialId);
    const button = passwordField.nextElementSibling;
    
    if (passwordField.type === 'password') {
      passwordField.type = 'text';
      button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><line x1="3" y1="3" x2="21" y2="21"/><path d="m10.584 10.587a2 2 0 0 0 2.828 2.83"/><path d="M9.363 5.365a9.466 9.466 0 0 1 2.637 -.365c4 0 7.333 2.333 10 7c-.778 1.361 -1.612 2.524 -2.503 3.488m-2.14 1.861c-1.631 1.1 -3.415 1.651 -5.357 1.651c-4 0 -7.333 -2.333 -10 -7c1.369 -2.395 2.913 -4.175 4.632 -5.341"/></svg>';
    } else {
      passwordField.type = 'password';
      button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/></svg>';
    }
  }
</script>
