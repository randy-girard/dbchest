<div id="<%= dom_id credential %>" class="credential-details">
  <div class="row">
    <div class="col-md-6">
      <dl class="row">
        <dt class="col-sm-4">Username:</dt>
        <dd class="col-sm-8">
          <div class="d-flex align-items-center">
            <span class="avatar avatar-sm me-2" style="background-image: url(https://ui-avatars.com/api/?name=<%= credential.username %>&background=dc3545&color=fff)"></span>
            <strong><%= credential.username %></strong>
          </div>
        </dd>
        
        <dt class="col-sm-4">Password:</dt>
        <dd class="col-sm-8">
          <div class="input-group">
            <input type="password" class="form-control" value="<%= credential.password %>" readonly id="password-<%= credential.id %>">
            <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('<%= credential.id %>')">
              <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
              </svg>
            </button>
          </div>
        </dd>
        
        <dt class="col-sm-4">Role:</dt>
        <dd class="col-sm-8">
          <span class="badge bg-info">
            <%= credential.respond_to?(:role) && credential.role.present? ? credential.role.humanize : 'User' %>
          </span>
        </dd>

        <dt class="col-sm-4">Status:</dt>
        <dd class="col-sm-8">
          <span class="badge bg-success">Active</span>
        </dd>
      </dl>
    </div>
    
    <div class="col-md-6">
      <dl class="row">
        <dt class="col-sm-4">Created:</dt>
        <dd class="col-sm-8">
          <%= credential.created_at.strftime("%B %d, %Y at %I:%M %p") %>
          <small class="text-muted d-block">(<%= time_ago_in_words(credential.created_at) %> ago)</small>
        </dd>
        
        <dt class="col-sm-4">Updated:</dt>
        <dd class="col-sm-8">
          <%= credential.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
          <small class="text-muted d-block">(<%= time_ago_in_words(credential.updated_at) %> ago)</small>
        </dd>

        <dt class="col-sm-4">Node:</dt>
        <dd class="col-sm-8">
          <% if defined?(@node) && @node %>
            <%= link_to @node.name, cluster_node_path(@cluster, @node), class: "text-decoration-none" %>
          <% elsif credential.respond_to?(:node) && credential.node %>
            <%= credential.node.name %>
          <% else %>
            <span class="text-muted">Unknown</span>
          <% end %>
        </dd>

        <dt class="col-sm-4">Cluster:</dt>
        <dd class="col-sm-8">
          <% if defined?(@cluster) && @cluster %>
            <%= link_to @cluster.name, cluster_path(@cluster), class: "text-decoration-none" %>
          <% elsif credential.respond_to?(:cluster) && credential.cluster %>
            <%= credential.cluster.name %>
          <% else %>
            <span class="text-muted">Unknown</span>
          <% end %>
        </dd>
      </dl>
    </div>
  </div>
  
  <% if credential.respond_to?(:description) && credential.description.present? %>
    <div class="mt-3">
      <dt>Description:</dt>
      <dd class="mt-2">
        <div class="card bg-light">
          <div class="card-body">
            <%= simple_format(credential.description) %>
          </div>
        </div>
      </dd>
    </div>
  <% end %>

  <!-- Security Information -->
  <div class="mt-4">
    <div class="card bg-light">
      <div class="card-header">
        <h4 class="card-title">Security Information</h4>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-3">
            <div class="text-muted small">Password Length</div>
            <div class="fw-bold"><%= credential.password.length %> characters</div>
          </div>
          <div class="col-md-3">
            <div class="text-muted small">Last Password Change</div>
            <div class="fw-bold">
              <%= time_ago_in_words(credential.updated_at) %> ago
            </div>
          </div>
          <div class="col-md-3">
            <div class="text-muted small">Access Level</div>
            <div class="fw-bold">
              <%= credential.respond_to?(:role) && credential.role.present? ? credential.role.humanize : 'Standard' %>
            </div>
          </div>
          <div class="col-md-3">
            <div class="text-muted small">Security Status</div>
            <div class="fw-bold text-success">Secure</div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Connection Strings -->
  <% connection_strings = credential.connection_strings %>
  <% if connection_strings.any? %>
    <div class="mt-4">
      <div class="card">
        <div class="card-header">
          <h4 class="card-title">
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M9 5h-2a2 2 0 0 0 -2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2 -2v-12a2 2 0 0 0 -2 -2h-2"/>
              <rect x="9" y="3" width="6" height="4" rx="2"/>
            </svg>
            Connection Strings
          </h4>
          <p class="text-muted small mb-0">Use these connection strings to connect to your database</p>
        </div>
        <div class="card-body">
          <% connection_strings.each do |format, value| %>
            <% next if format == :rails %> <!-- Skip Rails config for now, show it separately -->
            <div class="mb-3">
              <label class="form-label fw-bold text-uppercase small"><%= format %></label>
              <div class="input-group">
                <input type="text" class="form-control font-monospace small" value="<%= value.is_a?(Hash) ? value.to_json : value %>" readonly id="connection-<%= format %>-<%= credential.id %>">
                <button class="btn btn-outline-secondary" type="button" onclick="copyToClipboard('connection-<%= format %>-<%= credential.id %>')">
                  <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="20" height="20" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <rect x="8" y="8" width="12" height="12" rx="2"/>
                    <path d="M16 8v-2a2 2 0 0 0 -2 -2h-8a2 2 0 0 0 -2 2v8a2 2 0 0 0 2 2h2"/>
                  </svg>
                  Copy
                </button>
              </div>
            </div>
          <% end %>

          <% if connection_strings[:rails] %>
            <div class="mt-4">
              <label class="form-label fw-bold text-uppercase small">Rails Database Configuration</label>
              <div class="card bg-light">
                <div class="card-body">
                  <pre class="mb-0" id="connection-rails-config-<%= credential.id %>"><code><%= YAML.dump(connection_strings[:rails]).gsub(/^---\n/, '') %></code></pre>
                </div>
              </div>
              <button class="btn btn-sm btn-outline-secondary mt-2" type="button" onclick="copyRailsConfig('<%= credential.id %>')">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <rect x="8" y="8" width="12" height="12" rx="2"/>
                  <path d="M16 8v-2a2 2 0 0 0 -2 -2h-8a2 2 0 0 0 -2 2v8a2 2 0 0 0 2 2h2"/>
                </svg>
                Copy Rails Config
              </button>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<script>
  function togglePassword(credentialId) {
    const passwordField = document.getElementById('password-' + credentialId);
    const button = passwordField.nextElementSibling;

    if (passwordField.type === 'password') {
      passwordField.type = 'text';
      button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><line x1="3" y1="3" x2="21" y2="21"/><path d="m10.584 10.587a2 2 0 0 0 2.828 2.83"/><path d="M9.363 5.365a9.466 9.466 0 0 1 2.637 -.365c4 0 7.333 2.333 10 7c-.778 1.361 -1.612 2.524 -2.503 3.488m-2.14 1.861c-1.631 1.1 -3.415 1.651 -5.357 1.651c-4 0 -7.333 -2.333 -10 -7c1.369 -2.395 2.913 -4.175 4.632 -5.341"/></svg>';
    } else {
      passwordField.type = 'password';
      button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/><path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/></svg>';
    }
  }

  function copyToClipboard(elementId) {
    const element = document.getElementById(elementId);
    const text = element.value;

    navigator.clipboard.writeText(text).then(() => {
      // Show success feedback
      const button = element.nextElementSibling;
      const originalHTML = button.innerHTML;
      button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="icon text-success" width="20" height="20" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l5 5l10 -10"/></svg> Copied!';

      setTimeout(() => {
        button.innerHTML = originalHTML;
      }, 2000);
    }).catch(err => {
      console.error('Failed to copy:', err);
      alert('Failed to copy to clipboard');
    });
  }

  function copyRailsConfig(credentialId) {
    const configElement = document.querySelector(`#connection-rails-config-${credentialId}`);
    if (!configElement) return;

    const text = configElement.textContent;

    navigator.clipboard.writeText(text).then(() => {
      const button = event.target.closest('button');
      const originalHTML = button.innerHTML;
      button.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" class="icon text-success" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M5 12l5 5l10 -10"/></svg> Copied!';

      setTimeout(() => {
        button.innerHTML = originalHTML;
      }, 2000);
    }).catch(err => {
      console.error('Failed to copy:', err);
      alert('Failed to copy to clipboard');
    });
  }
</script>
