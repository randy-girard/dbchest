<<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Clusters", clusters_path %></li>
            <li class="breadcrumb-item"><%= link_to @cluster.name, cluster_path(@cluster) %></li>
            <li class="breadcrumb-item"><%= link_to @node.name, cluster_node_path(@cluster, @node) %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @credential.username %></li>
          </ol>
        </nav>
        <div class="page-pretitle">
          Credential Management
        </div>
        <h2 class="page-title">
          <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
            <circle cx="12" cy="16" r="1"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
          </svg>
          Database Credential: <%= @credential.username %>
          <span class="badge bg-success ms-2">Active</span>
        </h2>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <div class="btn-list">
          <%= link_to edit_cluster_node_credential_path(@cluster, @node, @credential), class: "btn btn-outline-primary" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
            </svg>
            Edit credential
          <% end %>
          <div class="dropdown">
            <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
              Actions
            </button>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="#">Test Connection</a></li>
              <li><a class="dropdown-item" href="#">Rotate Password</a></li>
              <li><a class="dropdown-item" href="#">View Usage Log</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><%= button_to "Delete Credential", [@cluster, @node, @credential], method: :delete, data: { confirm: "Are you sure you want to delete this credential? This action cannot be undone." }, class: "dropdown-item text-danger" %></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <div class="row">
      <!-- Credential Information -->
      <div class="col-lg-8">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Credential Details</h3>
          </div>
          <div class="card-body">
            <%= render @credential %>
          </div>
          <div class="card-footer">
            <div class="btn-list">
              <%= link_to "Back to node", cluster_node_path(@cluster, @node), class: "btn btn-outline-secondary" %>
              <%= button_to "Delete credential", [@cluster, @node, @credential], method: :delete, data: { confirm: "Are you sure you want to delete this credential? This action cannot be undone." }, class: "btn btn-danger ms-auto" %>
            </div>
          </div>
        </div>
      </div>

      <!-- Security & Usage Info -->
      <div class="col-lg-4">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Security Status</h3>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-6">
                <div class="text-muted small">Status</div>
                <div class="h4 text-success">Active</div>
              </div>
              <div class="col-6">
                <div class="text-muted small">Last Used</div>
                <div class="h4">Recently</div>
              </div>
            </div>
            <div class="mt-3">
              <div class="text-muted small mb-1">Password Strength</div>
              <div class="progress">
                <div class="progress-bar bg-success" style="width: 85%" role="progressbar"></div>
              </div>
              <div class="small text-muted">Strong</div>
            </div>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-header">
            <h3 class="card-title">Node Information</h3>
          </div>
          <div class="card-body">
            <dl class="mb-0">
              <dt class="small text-muted">Node Name:</dt>
              <dd class="small mb-2"><%= @node.name %></dd>
              
              <dt class="small text-muted">Cluster:</dt>
              <dd class="small mb-2">
                <%= link_to @cluster.name, cluster_path(@cluster), class: "text-decoration-none" %>
              </dd>
              
              <dt class="small text-muted">Provider:</dt>
              <dd class="small mb-2">
                <% if @node.provider %>
                  <%= @node.provider.name %>
                <% else %>
                  <span class="text-muted">Not assigned</span>
                <% end %>
              </dd>
              
              <dt class="small text-muted">Total Credentials:</dt>
              <dd class="small">
                <%= pluralize(@node.credentials.count, 'credential') %>
              </dd>
            </dl>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-header">
            <h3 class="card-title">Quick Actions</h3>
          </div>
          <div class="card-body">
            <div class="btn-list w-100">
              <%= link_to edit_cluster_node_credential_path(@cluster, @node, @credential), class: "btn btn-outline-primary w-100" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                  <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
                </svg>
                Edit Credential
              <% end %>
              <button class="btn btn-outline-secondary w-100" type="button">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 3a1 1 0 0 1 .117 1.993L12 5H9v4a1 1 0 0 1 -.883 .993L8 10a1 1 0 0 1 -1 -1V5H4a1 1 0 0 1 -1 -1a1 1 0 0 1 1 -1h8a1 1 0 0 1 1 1z"/>
                  <path d="M16 12h3v1a4 4 0 0 1 -4 4h-3v-1a4 4 0 0 1 4 -4z"/>
                </svg>
                Test Connection
              </button>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
