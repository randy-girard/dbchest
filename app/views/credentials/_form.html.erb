<div class="card">
  <div class="card-header">
    <h3 class="card-title">
      <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
        <circle cx="12" cy="16" r="1"/>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
      </svg>
      <%= credential.persisted? ? "Update Credential" : "Add Database Credential" %>
    </h3>
    <p class="card-subtitle">Database authentication setup</p>
  </div>

  <%= form_with(model: [@cluster, @node, credential], local: true, class: "card-body") do |form| %>
    <% if credential.errors.any? %>
      <div class="alert alert-danger alert-dismissible" role="alert">
        <div class="d-flex">
          <div>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <circle cx="12" cy="12" r="9"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <div>
            <h4 class="alert-title">Please fix the following errors:</h4>
            <ul class="mb-0">
              <% credential.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
        <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
      </div>
    <% end %>

    <div class="row">
      <div class="col-md-8">
        <div class="mb-3">
          <%= form.label :username, "Database Username", class: "form-label required" %>
          <%= form.text_field :username, class: "form-control #{'is-invalid' if credential.errors[:username].any?}", placeholder: "Enter database username", autofocus: true %>
          <div class="form-hint">
            Username for database authentication (e.g., 'admin', 'dbuser', 'app_user')
          </div>
          <% if credential.errors[:username].any? %>
            <div class="invalid-feedback">
              <%= credential.errors[:username].first %>
            </div>
          <% end %>
        </div>

        <div class="mb-3">
          <%= form.label :password, "Database Password", class: "form-label required" %>
          <%= form.password_field :password, class: "form-control #{'is-invalid' if credential.errors[:password].any?}", placeholder: "Enter secure password" %>
          <div class="form-hint">
            Strong password for database access. Use a secure, unique password.
          </div>
          <% if credential.errors[:password].any? %>
            <div class="invalid-feedback">
              <%= credential.errors[:password].first %>
            </div>
          <% end %>
        </div>

        <% if credential.respond_to?(:role) %>
          <div class="mb-3">
            <%= form.label :role, "Database Role", class: "form-label" %>
            <%= form.select :role, 
                [
                  ['Administrator', 'admin'],
                  ['Read/Write User', 'readwrite'],
                  ['Read Only User', 'readonly'],
                  ['Backup User', 'backup']
                ], 
                { prompt: "Select user role" },
                class: "form-select" %>
            <div class="form-hint">
              Define the permission level for this database user
            </div>
          </div>
        <% end %>

        <% if credential.respond_to?(:description) %>
          <div class="mb-3">
            <%= form.label :description, "Description", class: "form-label" %>
            <%= form.text_area :description, class: "form-control", rows: 2, placeholder: "Optional description or notes" %>
            <div class="form-hint">
              Additional notes about this credential or its intended use
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-md-4">
        <div class="card bg-light">
          <div class="card-body">
            <h4 class="card-title">Security Guidelines</h4>
            <div class="mb-2">
              <ul class="text-muted small mb-0">
                <li>Use strong, unique passwords</li>
                <li>Follow principle of least privilege</li>
                <li>Regularly rotate credentials</li>
                <li>Avoid sharing credentials</li>
                <li>Use role-based access control</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="card bg-info-lt mt-3">
          <div class="card-body">
            <h4 class="card-title">Node Information</h4>
            <div class="mb-2">
              <dl class="mb-0">
                <dt class="small text-muted">Node:</dt>
                <dd class="small"><%= @node.name %></dd>
                <dt class="small text-muted">Cluster:</dt>
                <dd class="small"><%= @cluster.name %></dd>
                <dt class="small text-muted">Provider:</dt>
                <dd class="small">
                  <%= @node.provider&.name || 'Not assigned' %>
                </dd>
              </dl>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card-footer bg-transparent mt-auto">
      <div class="btn-list">
        <%= link_to "Cancel", cluster_node_path(@cluster, @node), class: "btn btn-outline-secondary" %>
        <%= form.submit credential.persisted? ? "Update Credential" : "Add Credential", class: "btn btn-primary ms-auto" %>
      </div>
    </div>
  <% end %>
</div>
