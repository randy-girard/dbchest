<% content_for :title, "Dashboard - dbChest" %>

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Dashboard</h2>
        <div class="text-muted mt-1">Database infrastructure overview</div>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <div class="btn-list">
          <%= link_to new_cluster_path, class: "btn btn-primary" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <line x1="12" y1="5" x2="12" y2="19"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            New Cluster
          <% end %>
          <%= link_to new_provider_path, class: "btn btn-outline-primary" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <circle cx="12" cy="12" r="3"/>
              <path d="M12 1v6m0 6v6"/>
              <path d="m21 12l-6 0m-6 0l-6 0"/>
            </svg>
            New Provider
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <!-- Statistics Overview -->
    <div class="row g-3 mb-4">
      <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
          <div class="stat-label">Providers</div>
          <div class="stat-value"><%= @providers_count %></div>
          <div class="stat-change">
            <%= link_to "View all →", providers_path, class: "text-decoration-none small" %>
          </div>
        </div>
      </div>

      <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
          <div class="stat-label">Clusters</div>
          <div class="stat-value"><%= @clusters_count %></div>
          <div class="stat-change">
            <%= link_to "View all →", clusters_path, class: "text-decoration-none small" %>
          </div>
        </div>
      </div>

      <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
          <div class="stat-label">Nodes</div>
          <div class="stat-value"><%= @nodes_count %></div>
          <div class="stat-change text-muted small">
            Total database instances
          </div>
        </div>
      </div>

      <div class="col-sm-6 col-lg-3">
        <div class="stat-card">
          <div class="stat-label">System Status</div>
          <div class="stat-value">
            <span class="badge bg-success">Online</span>
          </div>
          <div class="stat-change">
            <%= link_to "Sidekiq →", "/sidekiq", target: "_blank", class: "text-decoration-none small" %>
          </div>
        </div>
      </div>
    </div>

    <!-- Recent Activity -->
    <div class="row">
      <div class="col-lg-6">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Recent Clusters</h3>
            <div class="card-actions">
              <%= link_to "View all →", clusters_path, class: "text-decoration-none small" %>
            </div>
          </div>
          <% if @recent_clusters.any? %>
            <div class="table-responsive">
              <table class="table table-sm table-vcenter">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Nodes</th>
                    <th>Created</th>
                  </tr>
                </thead>
                <tbody>
                  <% @recent_clusters.each do |cluster| %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center">
                          <span class="avatar avatar-sm me-2" style="background-image: url(https://ui-avatars.com/api/?name=<%= cluster.name %>&background=206bc4&color=fff)"></span>
                          <div>
                            <%= link_to cluster.name, cluster, class: "text-reset text-decoration-none fw-bold" %>
                            <div class="text-muted small"><%= cluster.database_type.name %></div>
                          </div>
                        </div>
                      </td>
                      <td>
                        <span class="fw-bold"><%= cluster.nodes.count %></span>
                      </td>
                      <td>
                        <span class="text-muted small"><%= time_ago_in_words(cluster.created_at) %> ago</span>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="empty">
              <div class="empty-img"><img src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/img/illustrations/undraw_software_engineer_lvl5.svg" height="128" alt=""></div>
              <p class="empty-title">No clusters yet</p>
              <p class="empty-subtitle text-muted">
                Get started by creating your first database cluster
              </p>
              <div class="empty-action">
                <%= link_to "Create cluster", new_cluster_path, class: "btn btn-primary" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="col-lg-6">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Recent Providers</h3>
            <div class="card-actions">
              <%= link_to "View all →", providers_path, class: "text-decoration-none small" %>
            </div>
          </div>
          <% if @recent_providers.any? %>
            <div class="table-responsive">
              <table class="table table-sm table-vcenter">
                <thead>
                  <tr>
                    <th>Name</th>
                    <th>Type</th>
                    <th>Created</th>
                  </tr>
                </thead>
                <tbody>
                  <% @recent_providers.each do |provider| %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center">
                          <span class="avatar avatar-sm me-2" style="background-image: url(https://ui-avatars.com/api/?name=<%= provider.name %>&background=17a2b8&color=fff)"></span>
                          <div>
                            <%= link_to provider.name, provider, class: "text-reset text-decoration-none fw-bold" %>
                          </div>
                        </div>
                      </td>
                      <td>
                        <span class="badge bg-info"><%= provider.provider_type.name %></span>
                      </td>
                      <td>
                        <span class="text-muted small"><%= time_ago_in_words(provider.created_at) %> ago</span>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="empty">
              <div class="empty-img"><img src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/img/illustrations/undraw_server_down_s4lk.svg" height="128" alt=""></div>
              <p class="empty-title">No providers yet</p>
              <p class="empty-subtitle text-muted">
                Add a provider to start managing your infrastructure
              </p>
              <div class="empty-action">
                <%= link_to "Add provider", new_provider_path, class: "btn btn-primary" %>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
