<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Clusters", clusters_path %></li>
            <li class="breadcrumb-item"><%= link_to @cluster.name, cluster_path(@cluster) %></li>
            <li class="breadcrumb-item"><%= link_to @node.name, cluster_node_path(@cluster, @node) %></li>
            <li class="breadcrumb-item active" aria-current="page">Delete</li>
          </ol>
        </nav>
        <div class="page-pretitle">Node Management</div>
        <h2 class="page-title">Delete Node: <%= @node.name %></h2>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <%= link_to "Cancel", cluster_node_path(@cluster, @node), class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <div class="row">
      <div class="col-12">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Replica Management Required</h3>
          </div>

            <div class="card-body">
              <div class="alert alert-warning">
                <div class="d-flex">
                  <div>
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <path d="M12 9v4"/>
                      <path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.87l-8.106 -13.536a1.914 1.914 0 0 0 -3.274 0z"/>
                      <path d="M12 16h.01"/>
                    </svg>
                  </div>
                  <div>
                    <h4 class="alert-title">This node has <%= @replicas.count %> replica(s)!</h4>
                    <div class="text-secondary">
                      You need to decide what to do with the following replica nodes:
                    </div>
                  </div>
                </div>
              </div>

              <% if @replicas.any? %>
                <div class="mb-4">
                  <h4>Replica Nodes:</h4>
                  <div class="list-group">
                    <% @replicas.each do |replica| %>
                      <div class="list-group-item">
                        <div class="row align-items-center">
                          <div class="col-auto">
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon text-muted" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <circle cx="12" cy="12" r="3"/>
                              <path d="M12 1v6m0 6v6"/>
                              <path d="m21 12l-6 0m-6 0l-6 0"/>
                            </svg>
                          </div>
                          <div class="col">
                            <div class="text-truncate">
                              <strong><%= replica.name %></strong>
                            </div>
                            <div class="text-secondary">
                              Provider: <%= replica.provider.name %> | 
                              Status: <span class="badge bg-<%= replica.status == 'running' ? 'success' : 'secondary' %>"><%= replica.status.titleize %></span>
                            </div>
                          </div>
                        </div>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>

              <div class="mb-4">
                <h4>Choose an action for the replica nodes:</h4>
                
                <div class="form-selectgroup form-selectgroup-boxes d-flex flex-column">
                  <label class="form-selectgroup-item flex-fill">
                    <input type="radio" name="replica_action" value="delete_all" class="form-selectgroup-input" id="delete_all">
                    <div class="form-selectgroup-label d-flex align-items-center p-3">
                      <div class="me-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon text-danger" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M4 7l16 0"/>
                          <path d="M10 11l0 6"/>
                          <path d="M14 11l0 6"/>
                          <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                          <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                        </svg>
                      </div>
                      <div class="form-selectgroup-label-content">
                        <span class="form-selectgroup-title"><strong>Delete All Replicas</strong></span>
                        <span class="d-block text-secondary">Remove the primary node and all its replicas. All data will be lost.</span>
                      </div>
                    </div>
                  </label>

                  <% if @replicas.count == 1 %>
                    <label class="form-selectgroup-item flex-fill">
                      <input type="radio" name="replica_action" value="promote_first" class="form-selectgroup-input" id="promote_replica">
                      <div class="form-selectgroup-label d-flex align-items-center p-3">
                        <div class="me-3">
                          <svg xmlns="http://www.w3.org/2000/svg" class="icon text-success" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <path d="M12 6l4 6l5 -4l-2 10h-14l-2 -10l5 4z"/>
                          </svg>
                        </div>
                        <div class="form-selectgroup-label-content">
                          <span class="form-selectgroup-title"><strong>Promote Replica to Primary</strong></span>
                          <span class="d-block text-secondary">The replica becomes the new primary node. Data is preserved.</span>
                        </div>
                      </div>
                    </label>
                  <% elsif @replicas.count > 1 %>
                    <label class="form-selectgroup-item flex-fill">
                      <input type="radio" name="replica_action" value="promote_first" class="form-selectgroup-input" id="promote_first">
                      <div class="form-selectgroup-label d-flex align-items-center p-3">
                        <div class="me-3">
                          <svg xmlns="http://www.w3.org/2000/svg" class="icon text-success" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <path d="M12 6l4 6l5 -4l-2 10h-14l-2 -10l5 4z"/>
                          </svg>
                        </div>
                        <div class="form-selectgroup-label-content">
                          <span class="form-selectgroup-title"><strong>Promote First Replica to Primary</strong></span>
                          <span class="d-block text-secondary">Promote "<%= @replicas.first.name %>" to primary. Other replicas will follow the new primary.</span>
                        </div>
                      </div>
                    </label>
                  <% end %>

                  <label class="form-selectgroup-item flex-fill">
                    <input type="radio" name="replica_action" value="detach_all" class="form-selectgroup-input" id="detach_all">
                    <div class="form-selectgroup-label d-flex align-items-center p-3">
                      <div class="me-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon text-info" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M12 3c7.2 0 9 1.8 9 9s-1.8 9 -9 9s-9 -1.8 -9 -9s1.8 -9 9 -9z"/>
                          <path d="M8 12h8"/>
                          <path d="M8 9h8"/>
                          <path d="M8 15h8"/>
                        </svg>
                      </div>
                      <div class="form-selectgroup-label-content">
                        <span class="form-selectgroup-title"><strong>Detach All Replicas</strong></span>
                        <span class="d-block text-secondary">Convert all replicas to independent primary nodes. No replication relationship.</span>
                      </div>
                    </div>
                  </label>
                </div>
              </div>

              <div class="alert alert-danger">
                <div class="d-flex">
                  <div>
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <path d="M12 9v4"/>
                      <path d="M10.363 3.591l-8.106 13.534a1.914 1.914 0 0 0 1.636 2.871h16.214a1.914 1.914 0 0 0 1.636 -2.87l-8.106 -13.536a1.914 1.914 0 0 0 -3.274 0z"/>
                      <path d="M12 16h.01"/>
                    </svg>
                  </div>
                  <div>
                    <h4 class="alert-title">Warning!</h4>
                    <p class="mb-0">This action cannot be undone. The primary node "<%= @node.name %>" will be permanently deleted from your infrastructure.</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="card-footer bg-transparent mt-auto">
              <div class="btn-list">
                <%= link_to "Cancel", cluster_node_path(@cluster, @node), class: "btn btn-outline-secondary" %>
                <button type="button" class="btn btn-danger ms-auto" onclick="confirmDelete()" disabled id="delete-btn">
                  Delete Node
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const radioButtons = document.querySelectorAll('input[name="replica_action"]');
  const deleteBtn = document.getElementById('delete-btn');

  // If there are no radio buttons (no replicas), enable the delete button immediately
  if (radioButtons.length === 0) {
    deleteBtn.disabled = false;
  } else {
    // If there are radio buttons, wait for one to be selected
    radioButtons.forEach(function(radio) {
      radio.addEventListener('change', function() {
        deleteBtn.disabled = false;
      });
    });
  }
});

function confirmDelete() {
  const radioButtons = document.querySelectorAll('input[name="replica_action"]');
  const selectedAction = document.querySelector('input[name="replica_action"]:checked');

  // If there are no radio buttons (no replicas), proceed with simple confirmation
  if (radioButtons.length === 0) {
    const confirmMessage = 'Are you sure you want to delete this node? This action cannot be undone.';
    if (confirm(confirmMessage)) {
      submitDeleteForm();
    }
    return;
  }

  // If there are radio buttons but none selected, show error
  if (!selectedAction) {
    alert('Please select an action for the replica nodes.');
    return;
  }

  const actionValue = selectedAction.value;
  let confirmMessage = '';

  switch(actionValue) {
    case 'delete_all':
      confirmMessage = 'Are you sure you want to delete this node and ALL its replicas? This will permanently remove all data.';
      break;
    case 'promote_first':
      confirmMessage = 'Are you sure you want to delete this node and promote the first replica to primary?';
      break;
    case 'detach_all':
      confirmMessage = 'Are you sure you want to delete this node and detach all replicas (making them independent)?';
      break;
  }

  if (confirm(confirmMessage)) {
    submitDeleteForm(actionValue);
  }
}

function submitDeleteForm(replicaAction = null) {
  // Create a form and submit it
  const form = document.createElement('form');
  form.method = 'POST';
  form.action = '<%= cluster_node_path(@cluster, @node) %>';

  const methodField = document.createElement('input');
  methodField.type = 'hidden';
  methodField.name = '_method';
  methodField.value = 'DELETE';
  form.appendChild(methodField);

  const csrfField = document.createElement('input');
  csrfField.type = 'hidden';
  csrfField.name = 'authenticity_token';
  csrfField.value = document.querySelector('meta[name="csrf-token"]').getAttribute('content');
  form.appendChild(csrfField);

  // Only add replica_action if it's provided (when there are replicas)
  if (replicaAction) {
    const actionField = document.createElement('input');
    actionField.type = 'hidden';
    actionField.name = 'replica_action';
    actionField.value = replicaAction;
    form.appendChild(actionField);
  }

  document.body.appendChild(form);
  form.submit();
}
</script>
