<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Clusters", clusters_path %></li>
            <li class="breadcrumb-item"><%= link_to @cluster.name, cluster_path(@cluster) %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @node.name %></li>
          </ol>
        </nav>
        <div class="page-pretitle">Node Management</div>
        <h2 class="page-title">
          <%= @node.name %>
          <%= node_status_badge(@node, class: 'ms-2') %>
        </h2>
        <div class="text-muted mt-1">
          <% if @node.replica? %>
            Replica of <%= @node.parent_node.name %> •
          <% else %>
            Primary node • <%= pluralize(@node.replicas.count, 'replica') %> •
          <% end %>
          <%= @node.provider.present? ? @node.provider.name : 'No provider' %> •
          <%= pluralize(@node.credentials.count, 'credential') %> •
          Created <%= time_ago_in_words(@node.created_at) %> ago
        </div>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <div class="btn-list">
          <%= link_to node_dashboard_path(@node), class: "btn btn-outline-info" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <rect x="3" y="4" width="18" height="12" rx="1"/>
              <line x1="7" y1="8" x2="17" y2="8"/>
              <line x1="7" y1="12" x2="17" y2="12"/>
              <line x1="7" y1="16" x2="13" y2="16"/>
            </svg>
            Metrics
          <% end %>
          <%= link_to edit_cluster_node_path(@cluster, @node), class: "btn btn-outline-primary" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
            </svg>
            Edit
          <% end %>
          <%= link_to new_cluster_node_credential_path(@cluster, @node), class: "btn btn-primary" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <line x1="12" y1="5" x2="12" y2="19"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Add Credential
          <% end %>
          <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
              <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <circle cx="12" cy="12" r="1"/>
                <circle cx="12" cy="19" r="1"/>
                <circle cx="12" cy="5" r="1"/>
              </svg>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
              <% if @node.primary? && @node.can_create_replicas? %>
                <li><%= link_to "Add Replica", add_replica_cluster_node_path(@cluster, @node), class: "dropdown-item" %></li>
              <% end %>
              <li><%= link_to "Back to Cluster", cluster_path(@cluster), class: "dropdown-item" %></li>
              <li><hr class="dropdown-divider"></li>
              <% if @node.has_replicas? %>
                <li><%= link_to "Delete Node", confirm_destroy_cluster_node_path(@cluster, @node), class: "dropdown-item text-danger" %></li>
              <% else %>
                <li><%= button_to "Delete Node", [@cluster, @node], method: :delete, data: { confirm: "Are you sure you want to delete this node? This action cannot be undone." }, class: "dropdown-item text-danger" %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl" data-controller="node-status" data-node-status-node-id-value="<%= @node.id %>" data-node-status-cluster-id-value="<%= @cluster.id %>">
    <div class="row">
      <!-- Node Information -->
      <div class="col-lg-12">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Node Details</h3>
          </div>
          <div class="card-body">
            <%= render @node %>
          </div>
        </div>

        <!-- Error Details (for failed nodes) -->
        <% if @node.error? && @node.error_details.present? %>
          <div class="alert alert-danger mt-4">
            <div class="d-flex">
              <div>
                <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <circle cx="12" cy="12" r="9"/>
                  <line x1="12" y1="12" x2="12" y2="8"/>
                  <line x1="12" y1="16" x2="12.01" y2="16"/>
                </svg>
              </div>
              <div>
                <h4 class="alert-title">Provisioning Error</h4>
                <div class="text-muted" style="white-space: pre-wrap; font-family: monospace; font-size: 0.875rem;">
                  <%= @node.error_details %>
                </div>
              </div>
            </div>
          </div>
        <% end %>

        <!-- Node Credentials -->
        <div class="card mt-4">
          <div class="card-header">
            <div class="row align-items-center">
              <div class="col">
                <h3 class="card-title">Database Credentials</h3>
              </div>
              <div class="col-auto">
                <%= link_to new_cluster_node_credential_path(@cluster, @node), class: "btn btn-primary btn-sm" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                  </svg>
                  Add Credential
                <% end %>
              </div>
            </div>
          </div>
          
          <% if @node.credentials.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @node.credentials.each do |credential| %>
                    <tr>
                      <td><strong><%= credential.username %></strong></td>
                      <td>
                        <span class="badge bg-info">
                          <%= credential.respond_to?(:role) && credential.role.present? ? credential.role.humanize : 'User' %>
                        </span>
                      </td>
                      <td class="text-muted">
                        <%= time_ago_in_words(credential.created_at) %> ago
                      </td>
                      <td>
                        <div class="btn-list flex-nowrap text-end">
                          <%= link_to cluster_node_credential_path(@cluster, @node, credential), class: "btn btn-sm btn-outline-primary" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                              <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                            </svg>
                          <% end %>
                          <%= link_to edit_cluster_node_credential_path(@cluster, @node, credential), class: "btn btn-sm btn-outline-secondary" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
                            </svg>
                          <% end %>
                          <%= button_to cluster_node_credential_path(@cluster, @node, credential), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <line x1="4" y1="7" x2="20" y2="7"/>
                              <line x1="10" y1="11" x2="10" y2="17"/>
                              <line x1="14" y1="11" x2="14" y2="17"/>
                              <path d="m5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                              <path d="m9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                            </svg>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="empty">
              <div class="empty-img">
                <img src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/img/illustrations/undraw_security_o890.svg" height="128" alt="">
              </div>
              <p class="empty-title">No credentials configured</p>
              <p class="empty-subtitle text-muted">
                Add database credentials to connect and manage this node.
              </p>
              <div class="empty-action">
                <%= link_to "Add first credential", new_cluster_node_credential_path(@cluster, @node), class: "btn btn-primary" %>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Node Replicas -->
        <div class="card mt-4">
          <div class="card-header">
            <div class="row align-items-center">
              <div class="col">
                <h3 class="card-title">
                  <% if @node.primary? %>
                    Read Replicas
                  <% else %>
                    Primary Node
                  <% end %>
                </h3>
              </div>
              <% if @node.primary? && @node.can_create_replicas? %>
                <div class="col-auto">
                  <%= link_to add_replica_cluster_node_path(@cluster, @node), class: "btn btn-primary btn-sm" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <line x1="12" y1="5" x2="12" y2="19"/>
                      <line x1="5" y1="12" x2="19" y2="12"/>
                    </svg>
                    Add Replica
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
          
          <% if @node.primary? && @node.replicas.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Replica Name</th>
                    <th>Provider</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @node.replicas.each do |replica| %>
                    <tr data-node-row-id="<%= replica.id %>">
                      <td><strong><%= replica.name %></strong></td>
                      <td>
                        <span class="badge bg-azure">
                          <%= replica.provider.name %>
                        </span>
                      </td>
                      <td>
                        <span class="<%= node_status_badge_class(replica) %>"
                              data-node-id="<%= replica.id %>"
                              data-node-status="<%= replica.id %>">
                          <%= node_status_display(replica) %>
                        </span>
                      </td>
                      <td class="text-muted">
                        <%= time_ago_in_words(replica.created_at) %> ago
                      </td>
                      <td>
                        <div class="btn-list flex-nowrap text-end">
                          <%= link_to [@cluster, replica], class: "btn btn-sm btn-outline-primary" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                              <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                            </svg>
                          <% end %>
                          <%= button_to [@cluster, replica], method: :delete, data: { confirm: "Are you sure you want to delete this replica?" }, class: "btn btn-sm btn-outline-danger" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <line x1="4" y1="7" x2="20" y2="7"/>
                              <line x1="10" y1="11" x2="10" y2="17"/>
                              <line x1="14" y1="11" x2="14" y2="17"/>
                              <path d="m5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                              <path d="m9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                            </svg>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% elsif @node.primary? %>
            <div class="empty">
              <p class="empty-title">No replicas configured</p>
              <p class="empty-subtitle text-muted">
                Add read replicas to scale your read operations.
              </p>
              <% if @node.can_create_replicas? %>
                <div class="empty-action">
                  <%= link_to "Add first replica", add_replica_cluster_node_path(@cluster, @node), class: "btn btn-primary" %>
                </div>
              <% else %>
                <div class="empty-action">
                  <p class="text-muted small">Primary node must be active before creating replicas</p>
                </div>
              <% end %>
            </div>
          <% else %>
            <div class="card-body">
              <div class="d-flex align-items-center">
                <span class="avatar me-3 bg-primary">P</span>
                <div>
                  <div class="fw-bold"><%= @node.parent_node.name %></div>
                  <div class="text-muted small">Primary database node</div>
                </div>
                <div class="ms-auto">
                  <%= link_to [@cluster, @node.parent_node], class: "btn btn-sm btn-outline-primary" do %>
                    View Primary
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>
