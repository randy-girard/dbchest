<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Clusters", clusters_path %></li>
            <li class="breadcrumb-item"><%= link_to @cluster.name, cluster_path(@cluster) %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @node.name %></li>
          </ol>
        </nav>
        <div class="page-pretitle">
          Node Management
        </div>
        <h2 class="page-title">
          <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 1v6m0 6v6"/>
            <path d="m21 12l-6 0m-6 0l-6 0"/>
          </svg>
          <%= @node.name %>
          <%= node_status_badge(@node, class: 'ms-2') %>
        </h2>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <div class="btn-list">
          <%= link_to edit_cluster_node_path(@cluster, @node), class: "btn btn-outline-primary" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
            </svg>
            Edit
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl" data-controller="node-status" data-node-status-node-id-value="<%= @node.id %>" data-node-status-cluster-id-value="<%= @cluster.id %>">
    <div class="row">
      <!-- Node Information -->
      <div class="col-lg-8">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Node Information</h3>
          </div>
          <div class="card-body">
            <%= render @node %>
          </div>
          <div class="card-footer">
            <div class="btn-list">
              <%= link_to "Back to cluster", cluster_path(@cluster), class: "btn btn-outline-secondary" %>
              <% if @node.has_replicas? %>
                <%= link_to "Delete node", confirm_destroy_cluster_node_path(@cluster, @node), class: "btn btn-danger ms-auto" %>
              <% else %>
                <%= button_to "Delete node", [@cluster, @node], method: :delete, data: { confirm: "Are you sure you want to delete this node? This action cannot be undone." }, class: "btn btn-danger ms-auto" %>
              <% end %>
            </div>
          </div>
        </div>

        <!-- Status Messages -->
        <div class="alert alert-info mt-4" data-node-status-message="<%= @node.id %>" style="display: none;">
          <div class="d-flex">
            <div>
              <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <circle cx="12" cy="12" r="9"/>
                <line x1="12" y1="8" x2="12.01" y2="8"/>
                <polyline points="11,12 12,12 12,16 13,16"/>
              </svg>
            </div>
            <div class="status-message-text">
            </div>
          </div>
        </div>

        <!-- Node Credentials -->
        <div class="card mt-4">
          <div class="card-header">
            <div class="row align-items-center">
              <div class="col">
                <h3 class="card-title">
                  <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                    <circle cx="12" cy="16" r="1"/>
                    <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                  </svg>
                  Database Credentials
                </h3>
                <p class="card-subtitle">User authentication and access control</p>
              </div>
              <div class="col-auto">
                <%= link_to new_cluster_node_credential_path(@cluster, @node), class: "btn btn-primary btn-sm" do %>
                  <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                  </svg>
                  Add Credential
                <% end %>
              </div>
            </div>
          </div>
          
          <% if @node.credentials.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @node.credentials.each do |credential| %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center">
                          <span class="avatar avatar-sm me-3" style="background-image: url(https://ui-avatars.com/api/?name=<%= credential.username %>&background=dc3545&color=fff)"></span>
                          <div>
                            <div class="fw-bold"><%= credential.username %></div>
                            <div class="text-muted small">Database user</div>
                          </div>
                        </div>
                      </td>
                      <td>
                        <span class="badge bg-info">
                          <%= credential.respond_to?(:role) ? credential.role : 'User' %>
                        </span>
                      </td>
                      <td>
                        <div class="text-muted">
                          <%= time_ago_in_words(credential.created_at) %> ago
                        </div>
                      </td>
                      <td>
                        <div class="btn-list flex-nowrap text-end">
                          <%= link_to cluster_node_credential_path(@cluster, @node, credential), class: "btn btn-sm btn-outline-primary" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                              <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                            </svg>
                          <% end %>
                          <%= link_to edit_cluster_node_credential_path(@cluster, @node, credential), class: "btn btn-sm btn-outline-secondary" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
                            </svg>
                          <% end %>
                          <%= button_to cluster_node_credential_path(@cluster, @node, credential), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <line x1="4" y1="7" x2="20" y2="7"/>
                              <line x1="10" y1="11" x2="10" y2="17"/>
                              <line x1="14" y1="11" x2="14" y2="17"/>
                              <path d="m5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                              <path d="m9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                            </svg>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% else %>
            <div class="empty">
              <div class="empty-img">
                <img src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/img/illustrations/undraw_security_o890.svg" height="128" alt="">
              </div>
              <p class="empty-title">No credentials configured</p>
              <p class="empty-subtitle text-muted">
                Add database credentials to connect and manage this node.
              </p>
              <div class="empty-action">
                <%= link_to "Add first credential", new_cluster_node_credential_path(@cluster, @node), class: "btn btn-primary" %>
              </div>
            </div>
          <% end %>
        </div>

        <!-- Node Replicas -->
        <div class="card mt-4">
          <div class="card-header">
            <div class="row align-items-center">
              <div class="col">
                <h3 class="card-title">
                  <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                    <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                    <path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"/>
                    <path d="M12 2l0 2"/>
                    <path d="M12 20l0 2"/>
                    <path d="M4.93 4.93l1.41 1.41"/>
                    <path d="M17.66 17.66l1.41 1.41"/>
                    <path d="M2 12l2 0"/>
                    <path d="M20 12l2 0"/>
                    <path d="M6.34 17.66l-1.41 1.41"/>
                    <path d="M19.07 4.93l-1.41 1.41"/>
                  </svg>
                  <% if @node.primary? %>
                    Read Replicas
                  <% else %>
                    Primary Node
                  <% end %>
                </h3>
                <p class="card-subtitle">
                  <% if @node.primary? %>
                    Manage read-only replicas for scaling read operations
                  <% else %>
                    This node is a replica of <%= link_to @node.parent_node.name, [@cluster, @node.parent_node], class: "text-decoration-none" %>
                  <% end %>
                </p>
              </div>
              <% if @node.primary? %>
                <div class="col-auto">
                  <% if @node.can_create_replicas? %>
                    <%= link_to add_replica_cluster_node_path(@cluster, @node), class: "btn btn-primary btn-sm" do %>
                      <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                      </svg>
                      Add Replica
                    <% end %>
                  <% else %>
                    <button class="btn btn-primary btn-sm" disabled title="Primary node must be active before creating replicas">
                      <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                        <line x1="12" y1="5" x2="12" y2="19"/>
                        <line x1="5" y1="12" x2="19" y2="12"/>
                      </svg>
                      Add Replica
                    </button>
                  <% end %>
                </div>
              <% end %>
            </div>
            
            <% if @node.primary? && !@node.can_create_replicas? %>
              <div class="alert alert-info mt-3" role="alert">
                <div class="d-flex">
                  <div>
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <circle cx="12" cy="12" r="9"/>
                      <line x1="12" y1="8" x2="12" y2="12"/>
                      <line x1="12" y1="16" x2="12.01" y2="16"/>
                    </svg>
                  </div>
                  <div>
                    <h4 class="alert-title">Replica Creation Unavailable</h4>
                    <div class="text-muted">This primary node must be <strong>active</strong> before replicas can be created. Current status: <span class="badge <%= @node.status_badge_class %>"><%= @node.status_display %></span></div>
                  </div>
                </div>
              </div>
            <% end %>
          </div>
          
          <% if @node.primary? && @node.replicas.any? %>
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Replica Name</th>
                    <th>Provider</th>
                    <th>Status</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% @node.replicas.each do |replica| %>
                    <tr data-node-row-id="<%= replica.id %>">
                      <td>
                        <div class="d-flex align-items-center">
                          <span class="avatar avatar-sm me-3 bg-dark">R</span>
                          <div>
                            <div class="fw-bold"><%= replica.name %></div>
                            <div class="text-muted small">Read replica</div>
                          </div>
                        </div>
                      </td>
                      <td>
                        <span class="badge bg-azure">
                          <%= replica.provider.name %>
                        </span>
                      </td>
                      <td>
                        <div>
                          <span class="<%= node_status_badge_class(replica) %>" 
                                data-node-id="<%= replica.id %>" 
                                data-node-status="<%= replica.id %>">
                            <%= node_status_display(replica) %>
                          </span>
                          <div class="small text-muted mt-1" 
                               data-node-status-message="<%= replica.id %>" 
                               style="display: none;">
                            <span class="status-message-text"></span>
                          </div>
                        </div>
                      </td>
                      <td>
                        <div class="text-muted">
                          <%= time_ago_in_words(replica.created_at) %> ago
                        </div>
                      </td>
                      <td>
                        <div class="btn-list flex-nowrap text-end">
                          <%= link_to [@cluster, replica], class: "btn btn-sm btn-outline-primary" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                              <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                            </svg>
                          <% end %>
                          <%= button_to [@cluster, replica], method: :delete, data: { confirm: "Are you sure you want to delete this replica?" }, class: "btn btn-sm btn-outline-danger" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <line x1="4" y1="7" x2="20" y2="7"/>
                              <line x1="10" y1="11" x2="10" y2="17"/>
                              <line x1="14" y1="11" x2="14" y2="17"/>
                              <path d="m5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                              <path d="m9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                            </svg>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          <% elsif @node.primary? %>
            <div class="empty">
              <div class="empty-img">
                <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="128" height="128" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"/>
                  <path d="M12 2l0 2"/>
                  <path d="M12 20l0 2"/>
                  <path d="M4.93 4.93l1.41 1.41"/>
                  <path d="M17.66 17.66l1.41 1.41"/>
                  <path d="M2 12l2 0"/>
                  <path d="M20 12l2 0"/>
                  <path d="M6.34 17.66l-1.41 1.41"/>
                  <path d="M19.07 4.93l-1.41 1.41"/>
                </svg>
              </div>
              <p class="empty-title">No replicas configured</p>
              <p class="empty-subtitle text-muted">
                Add read replicas to scale your read operations and improve performance.
              </p>
              <div class="empty-action">
                <%= link_to "Add first replica", add_replica_cluster_node_path(@cluster, @node), class: "btn btn-primary" %>
              </div>
            </div>
          <% else %>
            <div class="card-body">
              <div class="d-flex align-items-center">
                <span class="avatar me-3 bg-primary">P</span>
                <div>
                  <div class="fw-bold"><%= @node.parent_node.name %></div>
                  <div class="text-muted small">Primary database node</div>
                </div>
                <div class="ms-auto">
                  <%= link_to [@cluster, @node.parent_node], class: "btn btn-sm btn-outline-primary" do %>
                    View Primary
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <!-- Node Statistics -->
      <div class="col-lg-4">
        <div class="card">
          <div class="card-body">
            <div class="row g-3">
              <div class="col-6 text-center">
                <div class="h2 m-0 text-primary"><%= @node.credentials.count %></div>
                <div class="text-muted small">Credentials</div>
              </div>
              <div class="col-6 text-center">
                <div class="h2 m-0 text-success">
                  <% if @node.primary? %>
                    <%= @node.replicas.count %>
                  <% else %>
                    1
                  <% end %>
                </div>
                <div class="text-muted small">
                  <% if @node.primary? %>
                    Replicas
                  <% else %>
                    Primary
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-header">
            <h3 class="card-title">Node Health</h3>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-6">
                <div class="text-muted small">Status</div>
                <div class="h4 text-success">Online</div>
              </div>
              <div class="col-6">
                <div class="text-muted small">Last Check</div>
                <div class="h4">Just now</div>
              </div>
            </div>
          </div>
        </div>

        <div class="card mt-3">
          <div class="card-header">
            <h3 class="card-title">Quick Actions</h3>
          </div>
          <div class="card-body">
            <div class="btn-list w-100">
              <%= link_to new_cluster_node_credential_path(@cluster, @node), class: "btn btn-primary w-100 mb-2" do %>
                <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                  <circle cx="12" cy="16" r="1"/>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
                Add Credential
              <% end %>
              <% if @node.primary? %>
                <% if @node.can_create_replicas? %>
                  <%= link_to add_replica_cluster_node_path(@cluster, @node), class: "btn btn-secondary w-100" do %>
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"/>
                      <path d="M12 2l0 2"/>
                      <path d="M12 20l0 2"/>
                      <path d="M4.93 4.93l1.41 1.41"/>
                      <path d="M17.66 17.66l1.41 1.41"/>
                      <path d="M2 12l2 0"/>
                      <path d="M20 12l2 0"/>
                      <path d="M6.34 17.66l-1.41 1.41"/>
                      <path d="M19.07 4.93l-1.41 1.41"/>
                    </svg>
                    Add Replica
                  <% end %>
                <% else %>
                  <button class="btn btn-secondary w-100" disabled title="Primary node must be active before creating replicas">
                    <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                      <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                      <path d="M12 12m-4 0a4 4 0 1 0 8 0a4 4 0 1 0 -8 0"/>
                      <path d="M12 2l0 2"/>
                      <path d="M12 20l0 2"/>
                      <path d="M4.93 4.93l1.41 1.41"/>
                      <path d="M17.66 17.66l1.41 1.41"/>
                      <path d="M2 12l2 0"/>
                      <path d="M20 12l2 0"/>
                      <path d="M6.34 17.66l-1.41 1.41"/>
                      <path d="M19.07 4.93l-1.41 1.41"/>
                    </svg>
                    Add Replica (Node must be active)
                  </button>
                <% end %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
