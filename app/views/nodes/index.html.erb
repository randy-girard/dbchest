<% content_for :title, "Nodes" %>

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Clusters", clusters_path %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @cluster.name %></li>
          </ol>
        </nav>
        <div class="page-pretitle">Node Management</div>
        <h2 class="page-title">Nodes in <%= @cluster.name %></h2>
        <div class="text-muted mt-1"><%= pluralize(@nodes.count, 'node') %> total</div>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <%= link_to new_cluster_node_path(@cluster), class: "btn btn-primary" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <line x1="12" y1="5" x2="12" y2="19"/>
            <line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          New Node
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl" data-controller="node-status" data-node-status-cluster-id-value="<%= @cluster.id %>">
    <% if @nodes.any? %>
      <div class="card">
        <div class="table-responsive">
          <table class="table table-vcenter">
            <thead>
              <tr>
                <th>Node Name</th>
                <th>Type</th>
                <th>Provider</th>
                <th>Status</th>
                <th>Credentials</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @nodes.each do |node| %>
                <tr data-node-row-id="<%= node.id %>">
                  <td>
                    <div class="d-flex align-items-center">
                      <span class="avatar avatar-sm me-2" style="background-image: url(https://ui-avatars.com/api/?name=<%= node.name %>&background=<%= node.replica? ? 'ffc107' : '28a745' %>&color=fff)">
                        <%= node.replica? ? 'R' : 'P' %>
                      </span>
                      <div>
                        <div class="fw-bold"><%= link_to node.name, [@cluster, node], class: "text-reset text-decoration-none" %></div>
                        <div class="text-muted small">
                          <% if node.replica? %>
                            Replica of <%= node.parent_node.name %>
                          <% elsif node.has_replicas? %>
                            <%= pluralize(node.replicas.count, 'replica') %>
                          <% else %>
                            Primary
                          <% end %>
                        </div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <% if node.replica? %>
                      <span class="badge bg-warning">Replica</span>
                    <% else %>
                      <span class="badge bg-primary">Primary</span>
                    <% end %>
                  </td>
                  <td>
                    <% if node.provider.present? %>
                      <span class="badge bg-info"><%= node.provider.name %></span>
                    <% else %>
                      <span class="text-muted">—</span>
                    <% end %>
                  </td>
                  <td>
                    <div>
                      <%= node_status_badge(node) %>
                      <%= node_status_message_area(node, class: 'small text-muted mt-1') %>
                    </div>
                  </td>
                  <td>
                    <span class="fw-bold"><%= node.credentials.count %></span>
                    <span class="text-muted small ms-1"><%= 'credential'.pluralize(node.credentials.count) %></span>
                  </td>
                  <td>
                    <div class="text-muted"><%= time_ago_in_words(node.created_at) %> ago</div>
                    <div class="text-muted small"><%= node.created_at.strftime("%b %d, %Y") %></div>
                  </td>
                  <td>
                    <div class="btn-list justify-content-end">
                      <%= link_to node_dashboard_path(node), class: "btn btn-sm btn-outline-info", title: "Metrics" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <rect x="3" y="4" width="18" height="12" rx="1"/>
                          <line x1="7" y1="8" x2="17" y2="8"/>
                          <line x1="7" y1="12" x2="17" y2="12"/>
                          <line x1="7" y1="16" x2="13" y2="16"/>
                        </svg>
                      <% end %>
                      <%= link_to [@cluster, node], class: "btn btn-sm btn-outline-primary", title: "View Details" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                          <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                        </svg>
                      <% end %>
                      <%= link_to edit_cluster_node_path(@cluster, node), class: "btn btn-sm btn-outline-secondary", title: "Edit" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                          <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
                        </svg>
                      <% end %>
                      <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                          <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <circle cx="12" cy="12" r="1"/>
                            <circle cx="12" cy="19" r="1"/>
                            <circle cx="12" cy="5" r="1"/>
                          </svg>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                          <li><%= link_to "Add Credential", new_cluster_node_credential_path(@cluster, node), class: "dropdown-item" %></li>
                          <% if node.primary? && node.can_create_replicas? %>
                            <li><%= link_to "Add Replica", add_replica_cluster_node_path(@cluster, node), class: "dropdown-item" %></li>
                          <% end %>
                          <li><hr class="dropdown-divider"></li>
                          <li><%= button_to "Delete", [@cluster, node], method: :delete, data: { confirm: "Are you sure?" }, class: "dropdown-item text-danger" %></li>
                        </ul>
                      </div>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="empty">
        <div class="empty-img">
          <img src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/img/illustrations/undraw_server_down_s4lk.svg" height="128" alt="">
        </div>
        <p class="empty-title">No nodes in this cluster</p>
        <p class="empty-subtitle text-muted">
          Add your first database node to get started with this cluster.
        </p>
        <div class="empty-action">
          <%= link_to "Add first node", new_cluster_node_path(@cluster), class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
