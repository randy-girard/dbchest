<% content_for :title, "Nodes" %>

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Nodes</h2>
        <% if notice.present? %>
          <div class="alert alert-success mt-2"><%= notice %></div>
        <% end %>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <%= link_to "New Node", new_cluster_node_path(@cluster), class: "btn btn-primary" %>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl" data-controller="node-status" data-node-status-cluster-id-value="<%= @cluster.id %>">
    <div class="row row-cards">
      <% @nodes.each do |node| %>
        <div class="col-sm-6 col-lg-4" data-node-row-id="<%= node.id %>">
          <div class="card">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <h3 class="card-title mb-0"><%= node.name %></h3>
                <%= node_status_badge(node) %>
              </div>
              <p class="text-muted">
                <% if node.replica? %>
                  Replica of <%= node.parent_node.name %>
                <% else %>
                  Primary node
                  <% if node.has_replicas? %>
                    (<%= pluralize(node.replicas.count, 'replica') %>)
                  <% end %>
                <% end %>
              </p>
              <%= node_status_message_area(node, class: 'mb-2') %>
              <div class="mt-3">
                <%= link_to "View", [@cluster, node], class: "btn btn-outline-primary" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
