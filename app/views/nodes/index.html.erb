<% content_for :title, "Nodes" %>

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Nodes</h2>
        <% if notice.present? %>
          <div class="alert alert-success mt-2"><%= notice %></div>
        <% end %>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <%= link_to "New Node", new_cluster_node_path(@cluster), class: "btn btn-primary" %>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <div class="row row-cards">
      <% @nodes.each do |node| %>
        <div class="col-sm-6 col-lg-4">
          <div class="card">
            <div class="card-body">
              <h3 class="card-title"><%= node.name %></h3>
              <!-- You can render more node attributes here -->
              <p class="text-muted">
                <%= truncate(node.description, length: 100) if node.respond_to?(:description) %>
              </p>
              <div class="mt-3">
                <%= link_to "View", [@cluster, node], class: "btn btn-outline-primary" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
