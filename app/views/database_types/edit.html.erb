<% content_for :title, "Edit #{@database_type.name}" %>

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Database Types", database_types_path %></li>
            <li class="breadcrumb-item"><%= link_to @database_type.name, database_type_path(@database_type) %></li>
            <li class="breadcrumb-item active" aria-current="page">Edit</li>
          </ol>
        </nav>
        <div class="page-pretitle">Database Management</div>
        <h2 class="page-title">Edit Database Type: <%= @database_type.name %></h2>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <div class="btn-list">
          <%= link_to "Cancel", database_type_path(@database_type), class: "btn btn-outline-secondary" %>
          <% if @database_type.clusters.empty? %>
            <%= button_to "Delete", @database_type, method: :delete,
                        data: { confirm: "Are you sure you want to delete this database type?" },
                        class: "btn btn-outline-danger" %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <%= render 'form', database_type: @database_type %>
      </div>
    </div>
  </div>
</div>
