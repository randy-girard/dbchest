<% content_for :title, "New Database Type" %>

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Database Types", database_types_path %></li>
            <li class="breadcrumb-item active" aria-current="page">New</li>
          </ol>
        </nav>
        <div class="page-pretitle">Database Management</div>
        <h2 class="page-title">Create New Database Type</h2>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <%= link_to "Cancel", database_types_path, class: "btn btn-outline-secondary" %>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <div class="row justify-content-center">
      <div class="col-md-8">
        <%= render 'form', database_type: @database_type %>
      </div>
    </div>
  </div>
</div>
