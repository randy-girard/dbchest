<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "dbChest" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= action_cable_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/css/tabler.min.css" />
    <script src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/js/tabler.min.js"></script>

    <!-- Chart.js for metrics dashboards -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    
    <% if Rails.env.development? %>
      <script>
        // Debug ActionCable in development
        window.debugActionCable = function() {
          console.log("=== ActionCable Debug Info ===");
          console.log("ActionCable available:", typeof ActionCable !== 'undefined');
          console.log("createConsumer available:", typeof createConsumer !== 'undefined');
          console.log("WebSocket support:", typeof WebSocket !== 'undefined');
          console.log("Current URL:", window.location.href);
          
          // Extract ActionCable URL from meta tag
          const cableMeta = document.querySelector('meta[name="action-cable-url"]');
          console.log("ActionCable URL:", cableMeta ? cableMeta.content : 'Not found');
          
          // Find all node status controllers
          const controllers = document.querySelectorAll('[data-controller*="node-status"]');
          console.log("Node status controllers found:", controllers.length);
          controllers.forEach((el, i) => {
            console.log(`Controller ${i}:`, {
              element: el,
              nodeId: el.getAttribute('data-node-status-node-id-value'),
              clusterId: el.getAttribute('data-node-status-cluster-id-value')
            });
          });
          
          // Find all status elements
          const statusElements = document.querySelectorAll('[data-node-status]');
          console.log("Status elements found:", statusElements.length);
          statusElements.forEach((el, i) => {
            console.log(`Status element ${i}:`, {
              element: el,
              nodeId: el.getAttribute('data-node-status'),
              currentText: el.textContent,
              classes: el.className
            });
          });
        };
        
        // Helper to get the node status controller
        window.getNodeStatusController = function() {
          const element = document.querySelector('[data-controller*="node-status"]');
          if (element && window.application) {
            console.log("Found node status element:", element);
            
            // Wait for Stimulus to fully register the controller
            const checkController = () => {
              try {
                return window.application.getControllerForElementAndIdentifier(element, 'node-status');
              } catch (e) {
                return null;
              }
            };
            
            let controller = checkController();
            if (!controller) {
              // Try a few more times with delay
              setTimeout(() => {
                controller = checkController();
              }, 100);
            }
            
            try {
              return window.application.getControllerForElementAndIdentifier(element, 'node-status');
            } catch (e) {
              console.warn("Could not get controller:", e);
            }
          }
          
          // Don't log error if we're on a page that doesn't have the controller
          return null;
        };        // Test ActionCable availability
        window.testActionCableImport = function() {
          console.log("=== Testing ActionCable Import ===");
          console.log("ActionCable global:", typeof ActionCable);
          console.log("createConsumer global:", typeof createConsumer);
          
          if (typeof ActionCable !== 'undefined') {
            console.log("✅ ActionCable is available");
            try {
              const testConsumer = ActionCable.createConsumer();
              console.log("✅ Can create consumer:", testConsumer);
            } catch (e) {
              console.error("❌ Cannot create consumer:", e);
            }
          } else {
            console.error("❌ ActionCable not available globally");
          }
        };

        // Auto-run on page load in development
        document.addEventListener('DOMContentLoaded', function() {
          console.log("🔍 Running ActionCable diagnostics...");
          window.debugActionCable();
          window.testActionCableImport();
          
          // Make controller available globally for testing (only if node-status element exists)
          setTimeout(() => {
            const nodeStatusElement = document.querySelector('[data-controller*="node-status"]');
            if (nodeStatusElement) {
              window.nodeController = window.getNodeStatusController();
              if (window.nodeController) {
                console.log("🎮 Node controller available at window.nodeController");
                console.log("💡 Try: nodeController.testConnection() or nodeController.testBroadcast()");
              }
            } else {
              console.log("📄 No node status controller on this page - skipping initialization");
            }
          }, 2000);
        });
      </script>
    <% end %>
  </head>

  <body class="layout-sidebar">
    <header class="navbar navbar-expand-md navbar-light d-print-none">
      <div class="container-xl">
        <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#sidebar-menu" aria-controls="sidebar-menu" aria-expanded="false" aria-label="Toggle navigation">
          <span class="navbar-toggler-icon"></span>
        </button>
        <h1 class="navbar-brand navbar-brand-autodark d-none-navbar-horizontal pe-0 pe-md-3">
          <%= link_to root_path, class: "navbar-brand-autodark" do %>
            <img src="/icon.svg" width="110" height="32" alt="dbChest" class="navbar-brand-image">
          <% end %>
        </h1>
        <div class="navbar-nav flex-row order-md-last">
          <div class="d-none d-md-flex">
            <a href="?theme=dark" class="nav-link px-0 hide-theme-dark" title="Enable dark mode" data-bs-toggle="tooltip" data-bs-placement="bottom">
              <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <path d="M12 3c.132 0 .263 0 .393 0a7.5 7.5 0 0 0 7.92 12.446a9 9 0 1 1 -8.313 -12.454z"/>
              </svg>
            </a>
            <a href="?theme=light" class="nav-link px-0 hide-theme-light" title="Enable light mode" data-bs-toggle="tooltip" data-bs-placement="bottom">
              <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <circle cx="12" cy="12" r="4"/>
                <path d="m3 12h1m8 -9v1m8 8h1m-9 8v1m-6.4 -15.4l.7 .7m12.1 -.7l-.7 .7m0 11.4l.7 .7m-12.1 -.7l-.7 .7"/>
              </svg>
            </a>
          </div>
        </div>
      </div>
    </header>

    <aside class="navbar navbar-vertical navbar-expand-lg navbar-light">
      <div class="container-fluid">
        <%= render "shared/sidebar" %>
      </div>
    </aside>

    <div class="page-wrapper">
      <!-- Flash Messages -->
      <div class="flash-messages m-3">
        <%= render "shared/flash_messages" %>
      </div>
      
      <div class="page-body">
        <%= yield %>
      </div>
    </div>

    <% if Rails.env.development? %>
      <!-- Development Console for monitoring background jobs -->
      <div data-controller="development-console"></div>
    <% end %>
  </body>
</html>
