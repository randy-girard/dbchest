<div id="<%= dom_id provider %>" class="provider-details">
  <div class="row">
    <div class="col-md-6">
      <dl class="row">
        <dt class="col-sm-4">Provider Name:</dt>
        <dd class="col-sm-8"><strong><%= provider.name %></strong></dd>
        
        <dt class="col-sm-4">Type:</dt>
        <dd class="col-sm-8">
          <span class="badge bg-info fs-6"><%= provider.provider_type.name %></span>
        </dd>
        
        <dt class="col-sm-4">Status:</dt>
        <dd class="col-sm-8">
          <span class="badge bg-success">Connected</span>
        </dd>
      </dl>
    </div>
    
    <div class="col-md-6">
      <dl class="row">
        <dt class="col-sm-4">Created:</dt>
        <dd class="col-sm-8">
          <%= provider.created_at.strftime("%B %d, %Y at %I:%M %p") %>
          <small class="text-muted d-block">(<%= time_ago_in_words(provider.created_at) %> ago)</small>
        </dd>
        
        <dt class="col-sm-4">Updated:</dt>
        <dd class="col-sm-8">
          <%= provider.updated_at.strftime("%B %d, %Y at %I:%M %p") %>
          <small class="text-muted d-block">(<%= time_ago_in_words(provider.updated_at) %> ago)</small>
        </dd>
      </dl>
    </div>
  </div>
  
  <% if provider.respond_to?(:description) && provider.description.present? %>
    <div class="mt-3">
      <dt>Description:</dt>
      <dd class="mt-2">
        <div class="card bg-light">
          <div class="card-body">
            <%= simple_format(provider.description) %>
          </div>
        </div>
      </dd>
    </div>
  <% end %>
  
  <!-- Provider Configuration Summary -->
  <div class="mt-4">
    <div class="card bg-light">
      <div class="card-header">
        <h4 class="card-title">Configuration Summary</h4>
      </div>
      <div class="card-body">
        <div class="row">
          <div class="col-md-4">
            <div class="text-muted small">Provider Type</div>
            <div class="fw-bold"><%= provider.provider_type.name %></div>
          </div>
          <div class="col-md-4">
            <div class="text-muted small">Settings</div>
            <div class="fw-bold">
              <% if provider.respond_to?(:provider_settings) %>
                <%= pluralize(provider.provider_settings.count, 'setting') %>
              <% else %>
                0 settings
              <% end %>
            </div>
          </div>
          <div class="col-md-4">
            <div class="text-muted small">Associated Nodes</div>
            <div class="fw-bold">
              <% if provider.respond_to?(:nodes) %>
                <%= pluralize(provider.nodes.count, 'node') %>
              <% else %>
                0 nodes
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
