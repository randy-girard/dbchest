<% content_for :title, "Providers" %>

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Providers</h2>
        <% if notice.present? %>
          <div class="alert alert-success mt-2"><%= notice %></div>
        <% end %>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <%= link_to "New Provider", new_provider_path, class: "btn btn-primary" %>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <div class="row row-cards">
      <% @providers.each do |provider| %>
        <div class="col-sm-6 col-lg-4">
          <div class="card">
            <div class="card-body">
              <h3 class="card-title"><%= provider.name %></h3>
              <!-- Optional info -->
              <p class="text-muted">
                Type: <%= provider.provider_type.name %>
              </p>
              <div class="mt-3">
                <%= link_to "View", provider, class: "btn btn-outline-primary" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
