<% content_for :title, "Providers" %>

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <div class="page-pretitle">Infrastructure Management</div>
        <h2 class="page-title">Providers</h2>
        <div class="text-muted mt-1"><%= pluralize(@providers.count, 'provider') %> total</div>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <%= link_to new_provider_path, class: "btn btn-primary" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <line x1="12" y1="5" x2="12" y2="19"/>
            <line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          New Provider
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <% if @providers.any? %>
      <div class="card">
        <div class="table-responsive">
          <table class="table table-vcenter">
            <thead>
              <tr>
                <th>Provider Name</th>
                <th>Type</th>
                <th>Nodes</th>
                <th>Status</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @providers.each do |provider| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <span class="avatar avatar-sm me-2" style="background-image: url(https://ui-avatars.com/api/?name=<%= provider.name %>&background=17a2b8&color=fff)"></span>
                      <div>
                        <div class="fw-bold"><%= link_to provider.name, provider, class: "text-reset text-decoration-none" %></div>
                        <div class="text-muted small">ID: <%= provider.id %></div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span class="badge bg-info"><%= provider.provider_type.name %></span>
                  </td>
                  <td>
                    <% node_count = provider.respond_to?(:nodes) ? provider.nodes.count : 0 %>
                    <span class="fw-bold"><%= node_count %></span>
                    <span class="text-muted small ms-1"><%= 'node'.pluralize(node_count) %></span>
                  </td>
                  <td>
                    <span class="badge bg-success">Connected</span>
                  </td>
                  <td>
                    <div class="text-muted"><%= time_ago_in_words(provider.created_at) %> ago</div>
                    <div class="text-muted small"><%= provider.created_at.strftime("%b %d, %Y") %></div>
                  </td>
                  <td>
                    <div class="btn-list justify-content-end">
                      <%= link_to provider, class: "btn btn-sm btn-outline-primary", title: "View Details" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                          <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                        </svg>
                      <% end %>
                      <%= link_to edit_provider_path(provider), class: "btn btn-sm btn-outline-secondary", title: "Edit" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                          <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
                        </svg>
                      <% end %>
                      <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                          <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <circle cx="12" cy="12" r="1"/>
                            <circle cx="12" cy="19" r="1"/>
                            <circle cx="12" cy="5" r="1"/>
                          </svg>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                          <li><%= link_to "Test Connection", provider_path(provider), class: "dropdown-item" %></li>
                          <li><%= link_to "View Configuration", provider_path(provider), class: "dropdown-item" %></li>
                          <li><hr class="dropdown-divider"></li>
                          <li><%= button_to "Delete", provider, method: :delete, data: { confirm: "Are you sure?" }, class: "dropdown-item text-danger" %></li>
                        </ul>
                      </div>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="empty">
        <div class="empty-img">
          <img src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/img/illustrations/undraw_server_down_s4lk.svg" height="128" alt="">
        </div>
        <p class="empty-title">No providers found</p>
        <p class="empty-subtitle text-muted">
          Get started by adding your first infrastructure provider to manage your database clusters.
        </p>
        <div class="empty-action">
          <%= link_to "Add your first provider", new_provider_path, class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
