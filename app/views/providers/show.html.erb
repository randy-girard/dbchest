<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Providers", providers_path %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @provider.name %></li>
          </ol>
        </nav>
        <div class="page-pretitle">
          Infrastructure Management
        </div>
        <h2 class="page-title">
          <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <circle cx="12" cy="12" r="3"/>
            <path d="M12 1v6m0 6v6"/>
            <path d="m21 12l-6 0m-6 0l-6 0"/>
          </svg>
          <%= @provider.name %>
          <span class="badge bg-success ms-2">Connected</span>
        </h2>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <div class="btn-list">
          <%= link_to edit_provider_path(@provider), class: "btn btn-outline-primary" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
            </svg>
            Edit provider
          <% end %>
          <div class="dropdown">
            <button class="btn btn-primary dropdown-toggle" type="button" data-bs-toggle="dropdown">
              Actions
            </button>
            <ul class="dropdown-menu">
              <li><a class="dropdown-item" href="#">Test Connection</a></li>
              <li><a class="dropdown-item" href="#">View Logs</a></li>
              <li><a class="dropdown-item" href="#">Export Configuration</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><%= button_to "Delete Provider", @provider, method: :delete, data: { confirm: "Are you sure you want to delete this provider? This action cannot be undone." }, class: "dropdown-item text-danger" %></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <!-- Provider Overview -->
    <div class="row mb-4">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Provider Information</h3>
          </div>
          <div class="card-body">
            <%= render @provider %>
          </div>
          <div class="card-footer">
            <div class="btn-list">
              <%= link_to "Back to providers", providers_path, class: "btn btn-outline-secondary" %>
            </div>
          </div>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="card">
          <div class="card-body">
            <div class="text-center">
              <div class="h1 m-0">
                <% if @provider.respond_to?(:nodes) %>
                  <%= @provider.nodes.count %>
                <% else %>
                  0
                <% end %>
              </div>
              <div class="text-muted mb-3">Associated Nodes</div>
              <div class="progress mb-2">
                <div class="progress-bar bg-cyan" style="width: 75%" role="progressbar"></div>
              </div>
              <div class="text-muted small">Resource utilization</div>
            </div>
          </div>
        </div>
        
        <div class="card mt-3">
          <div class="card-header">
            <h3 class="card-title">Provider Health</h3>
          </div>
          <div class="card-body">
            <div class="row">
              <div class="col-6">
                <div class="text-muted small">Status</div>
                <div class="h4 text-success">Online</div>
              </div>
              <div class="col-6">
                <div class="text-muted small">Last Check</div>
                <div class="h4">Just now</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
