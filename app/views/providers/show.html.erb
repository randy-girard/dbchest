<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Providers", providers_path %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @provider.name %></li>
          </ol>
        </nav>
        <div class="page-pretitle">Infrastructure Management</div>
        <h2 class="page-title">
          <%= @provider.name %>
          <span class="badge bg-success ms-2">Connected</span>
        </h2>
        <div class="text-muted mt-1">
          <%= @provider.provider_type.name %> •
          <% node_count = @provider.respond_to?(:nodes) ? @provider.nodes.count : 0 %>
          <%= pluralize(node_count, 'node') %> •
          Created <%= time_ago_in_words(@provider.created_at) %> ago
        </div>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <div class="btn-list">
          <%= link_to edit_provider_path(@provider), class: "btn btn-outline-primary" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
            </svg>
            Edit
          <% end %>
          <div class="dropdown">
            <button class="btn btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
              <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <circle cx="12" cy="12" r="1"/>
                <circle cx="12" cy="19" r="1"/>
                <circle cx="12" cy="5" r="1"/>
              </svg>
            </button>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="#">Test Connection</a></li>
              <li><a class="dropdown-item" href="#">View Logs</a></li>
              <li><a class="dropdown-item" href="#">Export Configuration</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><%= link_to "Back to Providers", providers_path, class: "dropdown-item" %></li>
              <li><hr class="dropdown-divider"></li>
              <li><%= button_to "Delete Provider", @provider, method: :delete, data: { confirm: "Are you sure you want to delete this provider? This action cannot be undone." }, class: "dropdown-item text-danger" %></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <!-- Provider Details -->
    <div class="card mb-4">
      <div class="card-header">
        <h3 class="card-title">Provider Information</h3>
      </div>
      <div class="card-body">
        <%= render @provider %>
      </div>
    </div>

    <!-- Associated Nodes -->
    <% if @provider.respond_to?(:nodes) && @provider.nodes.any? %>
      <div class="card">
        <div class="card-header">
          <h3 class="card-title">Associated Nodes</h3>
          <div class="card-subtitle">Nodes using this provider</div>
        </div>
        <div class="table-responsive">
          <table class="table table-vcenter">
            <thead>
              <tr>
                <th>Node Name</th>
                <th>Cluster</th>
                <th>Type</th>
                <th>Status</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @provider.nodes.each do |node| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <span class="avatar avatar-sm me-2" style="background-image: url(https://ui-avatars.com/api/?name=<%= node.name %>&background=<%= node.replica? ? 'ffc107' : '28a745' %>&color=fff)">
                        <%= node.replica? ? 'R' : 'P' %>
                      </span>
                      <div>
                        <div class="fw-bold"><%= link_to node.name, [node.cluster, node], class: "text-reset text-decoration-none" %></div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <%= link_to node.cluster.name, node.cluster, class: "text-decoration-none" %>
                  </td>
                  <td>
                    <% if node.replica? %>
                      <span class="badge bg-warning">Replica</span>
                    <% else %>
                      <span class="badge bg-primary">Primary</span>
                    <% end %>
                  </td>
                  <td>
                    <%= node_status_badge(node) %>
                  </td>
                  <td>
                    <span class="text-muted small"><%= time_ago_in_words(node.created_at) %> ago</span>
                  </td>
                  <td>
                    <div class="btn-list justify-content-end">
                      <%= link_to [node.cluster, node], class: "btn btn-sm btn-outline-primary" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                          <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                        </svg>
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% end %>
  </div>
</div>
