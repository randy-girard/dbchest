<% content_for :title, "Edit #{@database_type.name} #{@database_type_version.version}" %>

<div class="container-xl">
  <div class="page-header d-print-none">
    <div class="row g-2 align-items-center">
      <div class="col">
        <div class="page-pretitle">
          <%= link_to "Database Types", database_types_path, class: "text-muted" %> / 
          <%= link_to @database_type.name, @database_type, class: "text-muted" %> /
          <%= link_to @database_type_version.version, [@database_type, @database_type_version], class: "text-muted" %>
        </div>
        <h2 class="page-title">
          Edit Version
        </h2>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <% if @database_type_version.nodes.empty? %>
          <%= link_to [@database_type, @database_type_version], method: :delete, 
                      confirm: "Are you sure you want to delete this version?", 
                      class: "btn btn-outline-danger" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <line x1="4" y1="7" x2="20" y2="7"/>
              <line x1="10" y1="11" x2="10" y2="17"/>
              <line x1="14" y1="11" x2="14" y2="17"/>
              <path d="M5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
              <path d="M9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
            </svg>
            Delete
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="row justify-content-center">
    <div class="col-md-10">
      <%= render 'form', database_type_version: @database_type_version %>
    </div>
  </div>
</div>
