<div class="card">
  <div class="card-header">
    <h3 class="card-title">
      <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
        <rect x="3" y="12" width="6" height="8" rx="1"/>
        <rect x="9" y="8" width="6" height="12" rx="1"/>
        <rect x="15" y="4" width="6" height="16" rx="1"/>
      </svg>
      <%= cluster.persisted? ? "Update Cluster" : "Create New Cluster" %>
    </h3>
    <p class="card-subtitle">Configure your database cluster settings</p>
  </div>

  <%= form_with(model: cluster, local: true, class: "card-body") do |form| %>
    <% if cluster.errors.any? %>
      <div class="alert alert-danger alert-dismissible" role="alert">
        <div class="d-flex">
          <div>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon alert-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <circle cx="12" cy="12" r="9"/>
              <line x1="12" y1="8" x2="12" y2="12"/>
              <line x1="12" y1="16" x2="12.01" y2="16"/>
            </svg>
          </div>
          <div>
            <h4 class="alert-title">Please fix the following errors:</h4>
            <ul class="mb-0">
              <% cluster.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
        <a class="btn-close" data-bs-dismiss="alert" aria-label="close"></a>
      </div>
    <% end %>

    <div class="row">
      <div class="col-md-8">
        <div class="mb-3">
          <%= form.label :name, class: "form-label required" %>
          <%= form.text_field :name, class: "form-control #{'is-invalid' if cluster.errors[:name].any?}", placeholder: "Enter cluster name", autofocus: true %>
          <div class="form-hint">
            Choose a descriptive name for your database cluster (e.g., "Production PostgreSQL", "Dev MySQL")
          </div>
          <% if cluster.errors[:name].any? %>
            <div class="invalid-feedback">
              <%= cluster.errors[:name].first %>
            </div>
          <% end %>
        </div>

        <div class="mb-3">
          <%= form.label :database_type_id, "Database Type", class: "form-label required" %>
          <%= form.collection_select :database_type_id, 
                                   @database_types, 
                                   :id, 
                                   :name, 
                                   { prompt: "Select a database type" }, 
                                   { class: "form-select #{'is-invalid' if cluster.errors[:database_type].any?}" } %>
          <div class="form-hint">
            Choose the type of database for this cluster (PostgreSQL, MySQL, etc.)
          </div>
          <% if cluster.errors[:database_type].any? %>
            <div class="invalid-feedback">
              <%= cluster.errors[:database_type].first %>
            </div>
          <% end %>
        </div>

        <% if cluster.respond_to?(:description) %>
          <div class="mb-3">
            <%= form.label :description, class: "form-label" %>
            <%= form.text_area :description, class: "form-control", rows: 3, placeholder: "Optional description for this cluster" %>
            <div class="form-hint">
              Provide additional details about this cluster's purpose and configuration
            </div>
          </div>
        <% end %>
      </div>

      <div class="col-md-4">
        <div class="card bg-light">
          <div class="card-body">
            <h4 class="card-title">Cluster Info</h4>
            <div class="mb-2">
              <small class="text-muted d-block">Next steps after creation:</small>
              <ul class="text-muted small mb-0">
                <li>Add database nodes</li>
                <li>Configure node settings</li>
                <li>Set up credentials</li>
                <li>Deploy infrastructure</li>
              </ul>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="card-footer bg-transparent mt-auto">
      <div class="btn-list">
        <%= link_to "Cancel", cluster.persisted? ? cluster : clusters_path, class: "btn btn-outline-secondary" %>
        <%= form.submit cluster.persisted? ? "Update Cluster" : "Create Cluster", class: "btn btn-primary ms-auto" %>
      </div>
    </div>
  <% end %>
</div>
