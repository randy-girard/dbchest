<% content_for :title, "Clusters" %>

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <div class="page-pretitle">Database Management</div>
        <h2 class="page-title">Clusters</h2>
        <div class="text-muted mt-1"><%= pluralize(@clusters.count, 'cluster') %> total</div>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <%= link_to new_cluster_path, class: "btn btn-primary" do %>
          <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <line x1="12" y1="5" x2="12" y2="19"/>
            <line x1="5" y1="12" x2="19" y2="12"/>
          </svg>
          New Cluster
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <% if @clusters.any? %>
      <div class="card">
        <div class="table-responsive">
          <table class="table table-vcenter">
            <thead>
              <tr>
                <th>Cluster Name</th>
                <th>Database Type</th>
                <th>Nodes</th>
                <th>Status</th>
                <th>Created</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @clusters.each do |cluster| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <span class="avatar avatar-sm me-2" style="background-image: url(https://ui-avatars.com/api/?name=<%= cluster.name %>&background=206bc4&color=fff)"></span>
                      <div>
                        <div class="fw-bold"><%= link_to cluster.name, cluster, class: "text-reset text-decoration-none" %></div>
                        <div class="text-muted small">ID: <%= cluster.id %></div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <span class="badge bg-info"><%= cluster.database_type.name %></span>
                  </td>
                  <td>
                    <div class="d-flex align-items-center">
                      <span class="fw-bold me-2"><%= cluster.nodes.count %></span>
                      <span class="text-muted small">
                        <% primary_count = cluster.nodes.where(parent_node_id: nil).count %>
                        <% replica_count = cluster.nodes.where.not(parent_node_id: nil).count %>
                        <%= "#{primary_count}P" if primary_count > 0 %>
                        <%= " / #{replica_count}R" if replica_count > 0 %>
                      </span>
                    </div>
                  </td>
                  <td>
                    <span class="badge bg-success">Active</span>
                  </td>
                  <td>
                    <div class="text-muted"><%= time_ago_in_words(cluster.created_at) %> ago</div>
                    <div class="text-muted small"><%= cluster.created_at.strftime("%b %d, %Y") %></div>
                  </td>
                  <td>
                    <div class="btn-list justify-content-end">
                      <%= link_to cluster_dashboard_path(cluster), class: "btn btn-sm btn-outline-info", title: "Metrics" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <rect x="3" y="4" width="18" height="12" rx="1"/>
                          <line x1="7" y1="8" x2="17" y2="8"/>
                          <line x1="7" y1="12" x2="17" y2="12"/>
                          <line x1="7" y1="16" x2="13" y2="16"/>
                        </svg>
                      <% end %>
                      <%= link_to cluster, class: "btn btn-sm btn-outline-primary", title: "View Details" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                          <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                        </svg>
                      <% end %>
                      <%= link_to new_cluster_node_path(cluster), class: "btn btn-sm btn-primary", title: "Add Node" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <line x1="12" y1="5" x2="12" y2="19"/>
                          <line x1="5" y1="12" x2="19" y2="12"/>
                        </svg>
                      <% end %>
                      <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                          <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <circle cx="12" cy="12" r="1"/>
                            <circle cx="12" cy="19" r="1"/>
                            <circle cx="12" cy="5" r="1"/>
                          </svg>
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end">
                          <li><%= link_to "Edit Cluster", edit_cluster_path(cluster), class: "dropdown-item" %></li>
                          <li><hr class="dropdown-divider"></li>
                          <li><%= button_to "Delete", cluster, method: :delete, data: { confirm: "Are you sure?" }, class: "dropdown-item text-danger" %></li>
                        </ul>
                      </div>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    <% else %>
      <div class="empty">
        <div class="empty-img">
          <img src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/img/illustrations/undraw_software_engineer_lvl5.svg" height="128" alt="">
        </div>
        <p class="empty-title">No clusters found</p>
        <p class="empty-subtitle text-muted">
          Get started by creating your first database cluster to manage your infrastructure.
        </p>
        <div class="empty-action">
          <%= link_to "Create your first cluster", new_cluster_path, class: "btn btn-primary" %>
        </div>
      </div>
    <% end %>
  </div>
</div>
