<% content_for :title, "Clusters" %>

<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <h2 class="page-title">Clusters</h2>
        <% if notice.present? %>
          <div class="alert alert-success mt-2"><%= notice %></div>
        <% end %>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <%= link_to "New Cluster", new_cluster_path, class: "btn btn-primary" %>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <div class="row row-cards">
      <% @clusters.each do |cluster| %>
        <div class="col-sm-6 col-lg-4">
          <div class="card">
            <div class="card-body">
              <h3 class="card-title"><%= cluster.name %></h3>
              <!-- Optional description or metadata -->
              <p class="text-muted">
                <%= truncate(cluster.description, length: 100) if cluster.respond_to?(:description) %>
              </p>
              <div class="mt-3">
                <%= link_to "View", cluster, class: "btn btn-outline-primary" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
