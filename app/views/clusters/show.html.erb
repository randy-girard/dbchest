<div class="page-header d-print-none">
  <div class="container-xl">
    <div class="row g-2 align-items-center">
      <div class="col">
        <nav aria-label="breadcrumb">
          <ol class="breadcrumb">
            <li class="breadcrumb-item"><%= link_to "Clusters", clusters_path %></li>
            <li class="breadcrumb-item active" aria-current="page"><%= @cluster.name %></li>
          </ol>
        </nav>
        <div class="page-pretitle">
          Cluster Management
        </div>
        <h2 class="page-title">
          <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
            <rect x="3" y="12" width="6" height="8" rx="1"/>
            <rect x="9" y="8" width="6" height="12" rx="1"/>
            <rect x="15" y="4" width="6" height="16" rx="1"/>
          </svg>
          <%= @cluster.name %>
          <span class="badge bg-success ms-2">Active</span>
        </h2>
      </div>
      <div class="col-auto ms-auto d-print-none">
        <div class="btn-list">
          <%= link_to edit_cluster_path(@cluster), class: "btn btn-outline-primary" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
            </svg>
            Edit
          <% end %>
          <%= link_to new_cluster_node_path(@cluster), class: "btn btn-primary" do %>
            <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
              <line x1="12" y1="5" x2="12" y2="19"/>
              <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Add Node
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>

<div class="page-body">
  <div class="container-xl">
    <!-- Cluster Overview -->
    <div class="row mb-4">
      <div class="col-md-8">
        <div class="card">
          <div class="card-header">
            <h3 class="card-title">Cluster Information</h3>
          </div>
          <div class="card-body">
            <%= render @cluster %>
          </div>
          <div class="card-footer">
            <div class="btn-list">
              <%= link_to "Back to clusters", clusters_path, class: "btn btn-outline-secondary" %>
              <%= button_to "Delete cluster", @cluster, method: :delete, data: { confirm: "Are you sure you want to delete this cluster? This action cannot be undone." }, class: "btn btn-danger ms-auto" %>
            </div>
          </div>
        </div>
      </div>
      
      <div class="col-md-4">
        <div class="card">
          <div class="card-body">
            <div class="text-center">
              <div class="h1 m-0"><%= @cluster.nodes.count %></div>
              <div class="text-muted mb-3">Total Nodes</div>
              <div class="progress mb-2">
                <div class="progress-bar bg-primary" style="width: <%= @cluster.nodes.count > 0 ? [@cluster.nodes.count * 25, 100].min : 0 %>%" role="progressbar"></div>
              </div>
              <div class="text-muted small">Cluster capacity utilization</div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Nodes Management -->
    <div class="card">
      <div class="card-header">
        <div class="row align-items-center">
          <div class="col">
            <h3 class="card-title">
              <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <circle cx="12" cy="12" r="3"/>
                <path d="M12 1v6m0 6v6"/>
                <path d="m21 12l-6 0m-6 0l-6 0"/>
              </svg>
              Nodes in this Cluster
            </h3>
            <p class="card-subtitle">Manage database nodes and their credentials</p>
          </div>
          <div class="col-auto">
            <%= link_to new_cluster_node_path(@cluster), class: "btn btn-primary btn-sm" do %>
              <svg xmlns="http://www.w3.org/2000/svg" class="icon me-1" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
              </svg>
              Add Node
            <% end %>
          </div>
        </div>
      </div>

      <% if @cluster.nodes.any? %>
        <div class="table-responsive">
          <table class="table table-hover align-middle">
            <thead>
              <tr>
                <th>Node</th>
                <th>Provider</th>
                <th>Status</th>
                <th>Credentials</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @cluster.nodes.each do |node| %>
                <tr>
                  <td>
                    <div class="d-flex align-items-center">
                      <span class="avatar avatar-sm me-3" style="background-image: url(https://ui-avatars.com/api/?name=<%= node.name %>&background=28a745&color=fff)"></span>
                      <div>
                        <div class="fw-bold"><%= node.name %></div>
                        <div class="text-muted small">Created <%= time_ago_in_words(node.created_at) %> ago</div>
                      </div>
                    </div>
                  </td>
                  <td>
                    <% if node.provider.present? %>
                      <span class="badge bg-info"><%= node.provider.name %></span>
                    <% else %>
                      <span class="text-muted">No provider</span>
                    <% end %>
                  </td>
                  <td>
                    <span class="badge bg-success">Active</span>
                  </td>
                  <td>
                    <span class="badge bg-secondary"><%= pluralize(node.credentials.count, 'credential') %></span>
                  </td>
                  <td>
                    <div class="btn-list flex-nowrap text-end">
                      <%= link_to cluster_node_path(@cluster, node), class: "btn btn-sm btn-outline-primary" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                          <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                        </svg>
                      <% end %>
                      <%= link_to edit_cluster_node_path(@cluster, node), class: "btn btn-sm btn-outline-secondary" do %>
                        <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                          <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                          <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                          <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
                        </svg>
                      <% end %>
                      <div class="dropdown">
                        <button class="btn btn-sm btn-outline-secondary dropdown-toggle" type="button" data-bs-toggle="dropdown">
                          <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                            <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                            <circle cx="12" cy="12" r="1"/>
                            <circle cx="12" cy="19" r="1"/>
                            <circle cx="12" cy="5" r="1"/>
                          </svg>
                        </button>
                        <ul class="dropdown-menu">
                          <% if node.credentials.any? %>
                            <li>
                              <button class="dropdown-item" type="button" data-bs-toggle="modal" data-bs-target="#credentialsModal-<%= node.id %>">
                                <svg xmlns="http://www.w3.org/2000/svg" class="icon dropdown-item-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                  <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                                  <circle cx="12" cy="16" r="1"/>
                                  <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                                </svg>
                                View Credentials
                              </button>
                            </li>
                          <% end %>
                          <li>
                            <%= link_to new_cluster_node_credential_path(@cluster, node), class: "dropdown-item" do %>
                              <svg xmlns="http://www.w3.org/2000/svg" class="icon dropdown-item-icon" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                                <line x1="12" y1="5" x2="12" y2="19"/>
                                <line x1="5" y1="12" x2="19" y2="12"/>
                              </svg>
                              Add Credential
                            <% end %>
                          </li>
                          <li><hr class="dropdown-divider"></li>
                          <li><%= button_to "Delete", cluster_node_path(@cluster, node), method: :delete, data: { confirm: "Are you sure?" }, class: "dropdown-item text-danger" %></li>
                        </ul>
                      </div>
                    </div>
                  </td>
                </tr>

              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="empty">
          <div class="empty-img">
            <img src="https://cdn.jsdelivr.net/npm/@tabler/core@1.4.0/dist/img/illustrations/undraw_server_down_s4lk.svg" height="128" alt="">
          </div>
          <p class="empty-title">No nodes in this cluster</p>
          <p class="empty-subtitle text-muted">
            Add your first database node to get started with this cluster.
          </p>
          <div class="empty-action">
            <%= link_to "Add first node", new_cluster_node_path(@cluster), class: "btn btn-primary" %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- Credentials Modals - Outside main page container to prevent scrolling issues -->
<% @cluster.nodes.each do |node| %>
  <% if node.credentials.any? %>
    <div class="modal modal-blur fade" id="credentialsModal-<%= node.id %>" tabindex="-1" role="dialog" aria-hidden="true">
      <div class="modal-dialog modal-lg modal-dialog-centered" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title">
              <svg xmlns="http://www.w3.org/2000/svg" class="icon me-2" width="24" height="24" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <circle cx="12" cy="16" r="1"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
              Credentials for <%= node.name %>
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <div class="table-responsive">
              <table class="table table-hover align-middle">
                <thead>
                  <tr>
                    <th>Username</th>
                    <th>Role</th>
                    <th>Created</th>
                    <th class="text-end">Actions</th>
                  </tr>
                </thead>
                <tbody>
                  <% node.credentials.each do |credential| %>
                    <tr>
                      <td>
                        <div class="d-flex align-items-center">
                          <span class="avatar avatar-sm me-3" style="background-image: url(https://ui-avatars.com/api/?name=<%= credential.username %>&background=dc3545&color=fff)"></span>
                          <div>
                            <div class="fw-bold"><%= credential.username %></div>
                            <div class="text-muted small">Database user</div>
                          </div>
                        </div>
                      </td>
                      <td>
                        <span class="badge bg-info">
                          <%= credential.respond_to?(:role) && credential.role.present? ? credential.role.humanize : 'User' %>
                        </span>
                      </td>
                      <td>
                        <div class="text-muted">
                          <%= time_ago_in_words(credential.created_at) %> ago
                        </div>
                      </td>
                      <td>
                        <div class="btn-list flex-nowrap text-end">
                          <%= link_to cluster_node_credential_path(@cluster, node, credential), class: "btn btn-sm btn-outline-primary", title: "View Details" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M10 12a2 2 0 1 0 4 0a2 2 0 0 0 -4 0"/>
                              <path d="M21 12c-2.4 4 -5.4 6 -9 6c-3.6 0 -6.6 -2 -9 -6c2.4 -4 5.4 -6 9 -6c3.6 0 6.6 2 9 6"/>
                            </svg>
                          <% end %>
                          <%= link_to edit_cluster_node_credential_path(@cluster, node, credential), class: "btn btn-sm btn-outline-secondary", title: "Edit" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <path d="M7 7h-1a2 2 0 0 0 -2 2v9a2 2 0 0 0 2 2h9a2 2 0 0 0 2 -2v-1"/>
                              <path d="M20.385 6.585a2.1 2.1 0 0 0 -2.97 -2.97l-8.415 8.385v3h3l8.385 -8.415z"/>
                            </svg>
                          <% end %>
                          <%= button_to cluster_node_credential_path(@cluster, node, credential), method: :delete, data: { confirm: "Are you sure?" }, class: "btn btn-sm btn-outline-danger", title: "Delete" do %>
                            <svg xmlns="http://www.w3.org/2000/svg" class="icon" width="16" height="16" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
                              <path stroke="none" d="M0 0h24v24H0z" fill="none"/>
                              <line x1="4" y1="7" x2="20" y2="7"/>
                              <line x1="10" y1="11" x2="10" y2="17"/>
                              <line x1="14" y1="11" x2="14" y2="17"/>
                              <path d="m5 7l1 12a2 2 0 0 0 2 2h8a2 2 0 0 0 2 -2l1 -12"/>
                              <path d="m9 7v-3a1 1 0 0 1 1 -1h4a1 1 0 0 1 1 1v3"/>
                            </svg>
                          <% end %>
                        </div>
                      </td>
                    </tr>
                  <% end %>
                </tbody>
              </table>
            </div>
          </div>
          <div class="modal-footer">
            <%= link_to "Add New Credential", new_cluster_node_credential_path(@cluster, node), class: "btn btn-primary" %>
            <button type="button" class="btn btn-secondary ms-auto" data-bs-dismiss="modal">Close</button>
          </div>
        </div>
      </div>
    </div>
  <% end %>
<% end %>
